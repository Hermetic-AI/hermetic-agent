@startuml openagent-architecture-overview
' ============================================================
' OpenAgent 5-Layer Architecture (v0.1 — 2026-06-05)
' 对应 docs/design/architecture-mermaid.md §1 的 PlantUML 版
' 渲染: plantuml openagent-architecture.puml
'       或 https://www.plantuml.com/plantuml/uml/ 粘贴源码
' ============================================================

title OpenAgent 5-Layer Architecture

' ============== 皮肤 ==============
skinparam backgroundColor       #FAFAFA
skinparam componentStyle        rectangle
skinparam packageStyle          rectangle
skinparam roundCorner           12
skinparam ArrowThickness        1.5
skinparam defaultTextAlignment  center
skinparam shadowing             false
skinparam nodesep               30
skinparam ranksep               40

' ============== 外部（顶 / 右） ==============
component "🖥  Frontend\n(React + TS + AUIRenderer)" as CLIENT #ECEFF1
component "⚙  External Engines\nopencode serve\nclaude-agent CLI"   as ENG   #ECEFF1

' ============== 5 层泳道 ==============
package "L1 · API Layer  (api/)" as L1 #E3F2FD {
    component "chat_controller · middleware\nscenario_controller · turn_routes" as L1N
}

package "L2 · Scenarios  (scenarios/)" as L2 #E8F5E9 {
    component "router · registry · loader\ninjector · scheduler_adapter" as L2N
}

package "L3 · Skill Runtime + AUIP + Core" as L3 #FFF3E0 {
    component "SuspendableScheduler · skill_runtime\nauip · turn_store" as L3N
}

package "L4 · Providers  (providers/)" as L4 #F3E5F5 {
    component "launcher · bridge\nopencode_adapter · claude_code_adapter" as L4N
}

package "L5 · Infrastructure  (policy/ · store/ · sandbox/)" as L5 #EEEEEE {
    component "policy · store · sandbox" as L5N
}

' ============== 资源（左） ==============
package "📂  work/ 资源目录" as WORK #FCE4EC {
    component "scenarios yaml\ncards · skills\nshared · cache" as WORKN
}

' ============== 主流程（粗箭头 ==>） ==============
CLIENT ==> L1N : POST /agent/chat
L1N    ==> L2N : scenario + inject
L2N    ==> L3N : SuspendableScheduler
L3N    ==> L4N : launch engine
L4N    ==> ENG  : SDK call

' ============== 资源读取（虚线 ..>） ==============
WORKN ..> L1N : yaml
WORKN ..> L2N : read
WORKN ..> L3N : fragments

' ============== 基础设施支撑（虚线 ..>） ==============
L1N ..> L5N
L2N ..> L5N
L3N ..> L5N
L4N ..> L5N

@enduml


' ============================================================
' 反向依赖约束（CI 强校验）
' ============================================================
@startuml openagent-reverse-constraints
title OpenAgent Reverse Dependency Constraints (CI enforced)

skinparam backgroundColor #FAFAFA
skinparam componentStyle rectangle
skinparam roundCorner 12

component "L1 API"           as L1 #E3F2FD
component "L2 Scenarios"     as L2 #E8F5E9
component "L3 Skill + AUIP"  as L3 #FFF3E0
component "L4 Providers"     as L4 #F3E5F5
component "L5 Infra"         as L5 #EEEEEE

' 允许的向下依赖
L1 ==> L2 : ok
L2 ==> L3 : ok
L3 ==> L4 : ok
L4 ==> L5 : ok
L3 ==> L5 : ok (direct)

' 禁止的反向依赖
L1 ..> L3 : FORBIDDEN #C62828
L1 ..> L4 : FORBIDDEN #C62828
L1 ..> L5 : FORBIDDEN #C62828
L2 ..> L4 : FORBIDDEN #C62828
L2 ..> L5 : FORBIDDEN #C62828
L3 ..> L1 : FORBIDDEN #C62828
L3 ..> L2 : FORBIDDEN #C62828
L4 ..> L1 : FORBIDDEN #C62828
L4 ..> L2 : FORBIDDEN #C62828
L4 ..> L3 : FORBIDDEN #C62828
L5 ..> L1 : FORBIDDEN #C62828
L5 ..> L2 : FORBIDDEN #C62828
L5 ..> L3 : FORBIDDEN #C62828
L5 ..> L4 : FORBIDDEN #C62828

@enduml


' ============================================================
' 部署 / 进程视图
' ============================================================
@startuml openagent-deployment-view
title OpenAgent Deployment / Process View

skinparam backgroundColor #FAFAFA
skinparam nodeStyle          rectangle
skinparam roundCorner        12

node "Browser\n(React + AUIRenderer)" as Browser #ECEFF1

node "Sanic Process\n(port 8000)" as Sanic #E3F2FD {
    component "L1 API\nchat_controller\nmiddleware" as L1
    component "L2 Scenarios\nregistry · router\ninjector · loader" as L2
    component "L3 Skill + AUIP\nSuspendableScheduler\nskill_runtime · auip" as L3
}

node "EngineLauncher" as Launcher #F3E5F5

node "opencode serve\n(HTTP :4096)\ncwd=${PROJECT_DIR}" as OC #F3E5F5
node "claude-agent CLI\n(per-session subprocess)\ncwd=${PROJECT_DIR}" as CC #F3E5F5

database "PostgreSQL\nSession/Message/Part" as PG #EEEEEE
database "Redis\nskill_context"            as RD #EEEEEE

folder "work/" as Work #FCE4EC {
    file "scenarios/*.yaml"   as Y1
    file "scenarios/{name}/\n{skills,cards,prompts}" as Y2
    file "shared/"           as Y3
}

' 流程
Browser  ==> Sanic  : HTTP/SSE
L1       ==> L2     : inject
L2       ==> L3     : schedule
L3       ==> Launcher : spawn engine
Launcher ==> OC     : opencode serve
Launcher ==> CC     : claude-agent CLI
OC       ==> Sanic  : SSE events
CC       ==> Sanic  : SDK events
Sanic    ==> PG     : persist session
L3       ==> RD     : skill_ctx
Sanic    ..> Work  : read YAML/cards
Launcher ..> Work  : cwd=

@enduml
