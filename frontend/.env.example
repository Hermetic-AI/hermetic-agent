# hermetic-agent Frontend Environment

# Backend base URL.  Empty string uses the Vite dev proxy at /api
# (proxy target is configured in vite.config.ts).
# In production builds, set to the absolute backend URL, e.g.
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# MCP token forwarded as the `X-MCP-Token` header on every request.
# 业务 SKILL 在 skill.yaml 的 required_envs 段声明自己需要的 env, 基座
# 会在每个 chat 之前把同名 env 写到 opencode 容器 env.runtime.
# Demo value for the example-echo-skill scenario used in dev.  Override
# in your own .env or build pipeline.
VITE_MCP_TOKEN=demo-token-replace-me
