# OpenAgent Frontend Environment

# Backend base URL.  Empty string uses the Vite dev proxy at /api
# (proxy target is configured in vite.config.ts).
# In production builds, set to the absolute backend URL, e.g.
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# MCP token forwarded as the `X-MCP-Token` header on every request.
# This is the per-tenant credential that the flight-query MCP server
# uses to authorise calls.  Leave empty during local development if
# the backend has anonymous access enabled.
VITE_MCP_TOKEN=
