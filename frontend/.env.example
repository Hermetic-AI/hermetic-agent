# OpenAgent Frontend Environment

# Backend base URL.  Empty string uses the Vite dev proxy at /api
# (proxy target is configured in vite.config.ts).
# In production builds, set to the absolute backend URL, e.g.
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# MCP token forwarded as the `X-MCP-Token` header on every request.
# Demo value for the flight-query scenario used in dev.  Override in
# your own .env or build pipeline.
VITE_MCP_TOKEN=u6lnte53n7i1oej1tt5f

# CRM token forwarded as the `X-CRM-Token` header on every request.
# This is the same token you get after logging into
# https://crmdev.feiheair.com/VuePage/index.html#/index
# (the CRM site authenticates against https://traveldev.feiheair.com/api/sys/logonV2).
#
# Two ways to set it:
#   1. Build-time (this env var):  baked into the bundle, requires rebuild.
#   2. Runtime (localStorage "crm_token"):  set via the Settings panel
#      inside the app, persisted across reloads.  Wins over the env var
#      if both are set.
#
# Either way, all frontend requests (chat / scenarios / pool / etc.) will
# carry the same `X-CRM-Token: <value>` header so the backend can use it
# for downstream Feihe travel API calls.
VITE_CRM_TOKEN=
