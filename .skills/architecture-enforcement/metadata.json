{
  "name": "architecture-enforcement",
  "version": "1.0.0",
  "description": "分层架构规则 enforcement：Controller→Service→Repository→Model，使用 importlinter (Python) 和 ArchUnit (Java)",
  "skill_type": "architecture-enforcement",
  "applicable_to": ["opencode", "claude-code", "codex-cli", "cursor", "openclaw", "maxclaw", "autoclaw", "kimiclaw", "trae"],
  "source_files": [
    "harness-rules/importlinter.toml",
    "harness-rules/archunit.java"
  ],
  "capabilities": {
    "python_layer_enforcement": {
      "tool": "importlinter",
      "description": "Python 分层架构检查",
      "layers": ["controllers", "services", "repositories", "models", "schemas", "utils", "events", "config", "middleware"],
      "rules": ["dependency-flow", "forbidden-direct-service-to-controller", "no-cross-layer-direct-calls", "no-utils-abuse"]
    },
    "java_layer_enforcement": {
      "tool": "ArchUnit",
      "description": "Java 分层架构检查",
      "rules": ["layeredArchitecture", "namingConventions", "serviceConstraints", "repositoryConstraints", "noFieldInjection"]
    },
    "circular_import_detection": {
      "description": "检测循环导入"
    },
    "utils_usage_analysis": {
      "description": "Utils 函数使用次数检查 (需 >= 3 次调用)"
    }
  },
  "architecture_layers": {
    "controllers": {
      "can_import_from": ["services", "models", "schemas", "utils", "config", "events", "middleware"],
      "forbidden": ["repositories"]
    },
    "services": {
      "can_import_from": ["repositories", "models", "schemas", "utils", "config", "events", "middleware"],
      "forbidden": ["controllers"]
    },
    "repositories": {
      "can_import_from": ["models", "config", "utils"],
      "forbidden": ["controllers", "services"]
    },
    "models": {
      "can_import_from": ["config", "utils"],
      "forbidden": ["services", "repositories", "controllers"]
    },
    "schemas": {
      "can_import_from": ["models", "config", "utils"],
      "forbidden": ["services", "repositories", "controllers"]
    },
    "utils": {
      "can_import_from": ["config", "models"],
      "forbidden": ["controllers", "services", "repositories", "hooks", "stores", "components"]
    },
    "events": {
      "can_import_from": ["models", "config", "utils", "schemas"],
      "forbidden": ["controllers", "services"]
    },
    "config": {
      "can_import_from": [],
      "forbidden": ["*"]
    }
  },
  "installation": {
    "python": "pip install importlinter",
    "java": "mvn dependency:get -Dartifact=com.tngtech.archunit:archunit-junit5:1.0.0"
  },
  "config_files": {
    "python": "importlinter.toml",
    "java": "src/test/java/com/example/ArchitectureTest.java"
  },
  "created": "2026-06-01",
  "tags": ["architecture", "layered", "importlinter", "archunit", "circular-import", "dependency-rules"]
}
