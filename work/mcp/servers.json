{
  "_comment": "Example MCP servers config — 业务方按需修改. 字段格式遵循 opencode MCP v1 协议.",
  "mcpServers": {
    "example-mcp": {
      "type": "remote",
      "url": "https://your-mcp-endpoint.example.com/api/mcp",
      "headers": {
        "Accept": "application/json,text/event-stream",
        "Authorization": "Bearer {env:MCP_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    }
  }
}
