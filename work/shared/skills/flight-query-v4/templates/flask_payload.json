{
  "$id": "flight-query-v4.templates.v1",
  "title": "flight-query-v4 完整 AUIP payload 模板",
  "description": "4 种 card_type 的 JSON 模板. LLM 调 ask_user 工具时, 按下面模板填字段; 必填项必填, 可选项省略.",
  "templates": {
    "flight_result": {
      "card_type": "FLIGHT_RESULT",
      "title": "机票已发送",
      "dismissible": false,
      "_llm_must_fill": ["plan_kind", "flightList"],
      "_llm_must_NOT_fill": ["plans", "flights"],
      "example": {
        "name": "ask_user",
        "input": {
          "card_type": "FLIGHT_RESULT",
          "title": "机票已发送",
          "plan_kind": "default",
          "flightList": [
            {
              "flightId": "CA1501-20260606-0900",
              "flightNo": "CA1501",
              "shareFlight": false,
              "airId": "CA",
              "lowestPrice": 550,
              "fullPrice": 1630,
              "totalDuration": "2h20m",
              "stopCount": 0,
              "depDate": "2026-06-06",
              "depAirportCode": "PEK",
              "arrAirportCode": "PVG",
              "lowestCabinName": "经济舱",
              "legs": [
                {
                  "airlineName": "中国国际航空",
                  "aircraftName": "波音 737",
                  "depTime": "09:00",
                  "arrTime": "11:20",
                  "depAirportName": "首都国际机场",
                  "arrAirportName": "浦东国际机场",
                  "depTerminal": "T3",
                  "arrTerminal": "T2",
                  "meal": true
                }
              ]
            }
          ]
        }
      }
    },
    "cannot_order": {
      "card_type": "CANNOT_ORDER",
      "title": "暂无法查询",
      "dismissible": true,
      "_llm_must_fill": ["reason", "fallback"],
      "example": {
        "name": "ask_user",
        "input": {
          "card_type": "CANNOT_ORDER",
          "title": "暂无符合条件的航班",
          "reason": "暂无符合条件的航班",
          "fallback": "建议: 放宽日期 / 换舱等 / 换 OD"
        }
      }
    },
    "ask_query": {
      "card_type": "ASK_QUERY",
      "title": "补充出行信息",
      "dismissible": false,
      "_llm_must_fill": ["missing"],
      "example": {
        "name": "ask_user",
        "input": {
          "card_type": "ASK_QUERY",
          "title": "补充出行信息",
          "missing": ["destination", "departDate"],
          "hints": {
            "origin": "例如 北京 / 上海 / 广州",
            "destination": "例如 东京 / 曼谷 / 纽约",
            "departDate": "例如 明天 / 2026-06-10"
          }
        }
      }
    },
    "chat_fallback": {
      "card_type": "CHAT_FALLBACK",
      "title": "查询失败",
      "dismissible": true,
      "_llm_must_fill": ["message"],
      "example": {
        "name": "ask_user",
        "input": {
          "card_type": "CHAT_FALLBACK",
          "title": "查询失败",
          "message": "机票查询服务暂时不可用, 请稍后重试"
        }
      }
    }
  },
  "_schema_legend": {
    "plan_kind": "default=3 方案 (最快/最便宜/直飞首选) | cheapest=1 方案最便宜 | fastest=1 方案最快 | comfortable=1 方案舒适首选 | user_explicit=1 方案用户已说'挑一个'",
    "missing": "string[] 字段名, 后端按字段名渲染对应表单输入框",
    "hints": "Record<fieldName, hintText> 可选, 给用户看的输入提示"
  }
}
