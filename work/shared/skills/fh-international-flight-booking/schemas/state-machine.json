{
  "initial": "INIT",
  "states": {
    "INIT": {
      "description": "初始状态，等待意图识别",
      "transitions": ["PERMISSION_CHECKED"]
    },
    "PERMISSION_CHECKED": {
      "description": "权限校验通过，等待搜索参数",
      "transitions": ["SEARCH_PARAMS_READY"]
    },
    "SEARCH_PARAMS_READY": {
      "description": "搜索参数就绪，准备查询",
      "transitions": ["FLIGHT_LISTED"]
    },
    "FLIGHT_LISTED": {
      "description": "航班列表已展示，等待用户选择",
      "transitions": ["GROUP_SELECTED"]
    },
    "GROUP_SELECTED": {
      "description": "航班组合已选定，展示价格方案",
      "transitions": ["PRICE_SELECTED"]
    },
    "PRICE_SELECTED": {
      "description": "价格方案已选定，待核价",
      "transitions": ["RULE_CHECKED", "PRICING_VERIFIED"]
    },
    "RULE_CHECKED": {
      "description": "退改规则已查看",
      "transitions": ["PRICING_VERIFIED"]
    },
    "PRICING_VERIFIED": {
      "description": "核价通过，待差标校验",
      "transitions": ["POLICY_CHECKED"]
    },
    "POLICY_CHECKED": {
      "description": "差标校验通过，待获取下单数据",
      "transitions": ["WAIT_SAVE_LOADED"]
    },
    "WAIT_SAVE_LOADED": {
      "description": "待下单数据已获取，待填乘机人",
      "transitions": ["PASSENGER_FILLED"]
    },
    "PASSENGER_FILLED": {
      "description": "乘机人已填，待提交订单",
      "transitions": ["ORDER_SUBMITTED"]
    },
    "ORDER_SUBMITTED": {
      "description": "订单已提交，待支付验证",
      "transitions": ["PAYMENT_VERIFIED"]
    },
    "PAYMENT_VERIFIED": {
      "description": "支付已验证",
      "transitions": ["FINISHED"]
    },
    "FINISHED": {
      "description": "下单完成",
      "transitions": []
    },
    "CANNOT_ORDER": {
      "description": "终态：权限/风控/网络阻断",
      "transitions": []
    }
  },
  "back_transitions": {
    "FLIGHT_LISTED": ["SEARCH_PARAMS_READY"],
    "GROUP_SELECTED": ["FLIGHT_LISTED"],
    "PRICE_SELECTED": ["GROUP_SELECTED"],
    "PRICING_VERIFIED": ["PRICE_SELECTED"],
    "POLICY_CHECKED": ["PRICING_VERIFIED"],
    "WAIT_SAVE_LOADED": ["POLICY_CHECKED"],
    "PASSENGER_FILLED": ["WAIT_SAVE_LOADED"]
  }
}
