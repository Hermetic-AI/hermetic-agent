{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntShoppingRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["stopQuantity", "onlyBigCustomerPrice", "language", "passengerType", "tripList"],
  "properties": {
    "stopQuantity": {
      "type": "integer",
      "enum": [0, 1, 2],
      "description": "经停次数: 0直飞 1经停一次 2经停二次"
    },
    "onlyBigCustomerPrice": {
      "type": "boolean",
      "description": "仅查大客户价"
    },
    "clientId": {
      "type": "string",
      "description": "企业客户ID"
    },
    "language": {
      "type": "string",
      "enum": ["cn", "en"],
      "description": "语言"
    },
    "airIdList": {
      "type": "array",
      "items": {"type": "string"},
      "description": "航司二字码列表"
    },
    "passengerType": {
      "type": "string",
      "enum": ["ADT", "CHD", "INF"],
      "description": "乘客类型"
    },
    "cabClass": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["FIRST", "PREMIUM_FIRST", "BUSINESS", "PREMIUM_BUSINESS", "ECONOMY", "PREMIUM_ECONOMY"]
      },
      "description": "舱位等级"
    },
    "tripList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["fromCity", "toCity", "flyDate", "isCity"],
        "properties": {
          "fromCity": {"type": "string", "minLength": 3, "maxLength": 3, "description": "出发城市三字码"},
          "toCity": {"type": "string", "minLength": 3, "maxLength": 3, "description": "到达城市三字码"},
          "flyDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "起飞日期 yyyy-MM-dd"},
          "isCity": {"type": "boolean", "description": "是否城市码"}
        }
      }
    },
    "preferences": {
      "type": "object",
      "properties": {
        "transport": {"type": "array", "items": {"type": "string"}},
        "allianceCode": {"type": "string", "enum": ["OW", "SA", "ST"], "description": "联盟代码"},
        "changeable": {"type": "boolean"},
        "refundable": {"type": "boolean"},
        "upgradable": {"type": "boolean"},
        "freeBaggageOnly": {"type": "boolean"}
      }
    }
  }
}
