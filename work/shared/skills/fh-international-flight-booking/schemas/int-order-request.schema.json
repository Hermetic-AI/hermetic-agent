{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntOrderRequest",
  "type": "object",
  "additionalProperties": true,
  "required": ["flightList", "passengerList"],
  "properties": {
    "outlayType": {"type": "string", "enum": ["0", "1"], "description": "0自费 1公费"},
    "interfaceSupplier": {"type": "string"},
    "savePassenger": {"type": "string"},
    "clientId": {"type": "string"},
    "payType": {"type": "string", "enum": ["0", "3", "4"], "description": "0挂账 3在线支付 4银行转账"},
    "orderer": {"type": "string", "description": "联系人姓名"},
    "orderTel": {"type": "string", "description": "联系人手机"},
    "userCode": {"type": "string", "description": "联系人工号"},
    "orderMail": {"type": "string"},
    "noadvanceReason": {"type": "string", "description": "出差事由"},
    "applicationDh": {"type": "string", "description": "出差申请单单号"},
    "applicationId": {"type": "string", "description": "出差申请单ID"},
    "depId": {"type": "string", "description": "成本中心"},
    "projectName": {"type": "string"},
    "belongProjectCode": {"type": "string"},
    "belongCompany": {"type": "string"},
    "belongCompanyCode": {"type": "string"},
    "depName": {"type": "string"},
    "needAddress": {"type": "string", "enum": ["0", "1"], "description": "1需要送货地址"},
    "deliverType": {"type": "string", "enum": ["2", "3"], "description": "2单独配送 3免送货"},
    "budgetCode": {"type": "string"},
    "specificPolicy": {"type": "boolean"},
    "travelPolicyList": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "passengerList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "passengerType", "idType", "idNumber"],
        "properties": {
          "cardId": {"type": "integer"},
          "name": {"type": "string", "description": "格式: LastName/FirstName"},
          "passengerName": {"type": "string", "description": "中文名称"},
          "passengerType": {"type": "string", "enum": ["0","1","2","3","4","5","6","7","8"]},
          "issueCountry": {"type": "string", "description": "发证国家 CN"},
          "nationality": {"type": "string", "description": "国籍代码"},
          "idType": {"type": "string", "enum": ["0","1","2","3","4"]},
          "userCode": {"type": "string"},
          "depId": {"type": "integer"},
          "idNumber": {"type": "string"},
          "idExpiration": {"type": "string"},
          "gender": {"type": "string", "enum": ["0","1"]},
          "birthday": {"type": "string"},
          "phoneNumber": {"type": "string"},
          "bx1": {"type": "integer"},
          "bx2": {"type": "integer"},
          "mileageList": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "airId": {"type": "string"},
                "mileageCardAirId": {"type": "string"},
                "mileageCard": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "flightList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["serialNumber", "priceId", "pricingId"],
        "properties": {
          "serialNumber": {"type": "string"},
          "priceId": {"type": "string"},
          "pricingId": {"type": "string"}
        }
      }
    },
    "additionalList": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "code": {"type": "string"},
          "name": {"type": "string"},
          "noteText": {"type": "string"}
        }
      }
    },
    "receiver": {
      "type": "object",
      "properties": {
        "contact": {"type": "string"},
        "clientTel": {"type": "string"},
        "sendAddress": {"type": "string"}
      }
    }
  }
}
