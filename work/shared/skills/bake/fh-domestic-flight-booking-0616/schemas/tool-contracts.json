{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FH Domestic Flight MCP Tool Contracts",
  "tools": {
    "checkProductAccess": {"required": ["sessionId"], "stages": ["INIT", "TRIP_CONFIRMED", "FLIGHT_LISTED", "FLIGHT_SELECTED", "CABIN_SELECTED", "PASSENGER_FILLED"]},
    "queryFlightBasic": {"required": ["departureCity", "arrivalCity", "departureDate"], "stages": ["INIT", "TRIP_CONFIRMED", "FLIGHT_LISTED", "FLIGHT_SELECTED"]},
    "filterFlightList": {"required": ["sessionId"], "stages": ["FLIGHT_LISTED"]},
    "chooseFlight": {"required": ["sessionId"], "requiredOneOf": ["index", "flightNo"], "stages": ["FLIGHT_LISTED", "FLIGHT_SELECTED"]},
    "getFlightPolicyInfo": {"required": ["sessionId", "index"], "stages": ["FLIGHT_LISTED", "FLIGHT_SELECTED"]},
    "chooseCabin": {"required": ["sessionId"], "requiredOneOf": ["index", "cabinName", "cabId", "price"], "stages": ["FLIGHT_SELECTED", "CABIN_SELECTED"]},
    "chooseAlternativeCabin": {"required": ["sessionId", "cabId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED", "INFO_VALIDATED", "PRICE_CONFIRMED"]},
    "listTripApplications": {"required": ["sessionId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "getTripApplicationDetail": {"required": ["sessionId", "tripApplicationId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "listCostCenters": {"required": ["sessionId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "bindCostCenter": {"required": ["sessionId", "costCenterId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "getDefaultContact": {"required": ["sessionId"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "fillPassenger": {"required": ["sessionId", "names"], "stages": ["CABIN_SELECTED", "PASSENGER_FILLED"]},
    "validateBookingInfo": {"required": ["sessionId"], "stages": ["PASSENGER_FILLED", "INFO_VALIDATED", "PRICE_CONFIRMED"]},
    "recordPolicyUserDecision": {"required": ["sessionId", "decisionCode"], "stages": ["PASSENGER_FILLED", "INFO_VALIDATED", "PRICE_CONFIRMED"]},
    "buildOrderPreview": {"required": ["sessionId"], "stages": ["INFO_VALIDATED", "PRICE_CONFIRMED", "ORDER_PREVIEWED"]},
    "getOrderDetail": {"required": ["orderId"], "stages": ["*"]},
    "resetBookingSession": {"required": ["sessionId"], "stages": ["*"]},
    "getDateInfo": {"required": [], "stages": ["*"]},
    "listUpcomingHolidays": {"required": [], "stages": ["*"]},
    "getHolidayDate": {"required": ["holidayName"], "stages": ["*"]}
  },
  "enums": {
    "roundTripListMode": ["RECOMMENDED", "FREE"],
    "cabinClass": ["ECONOMY", "FULL_ECONOMY", "BUSINESS", "FIRST"],
    "departureDayPart": ["MORNING", "AFTERNOON", "EVENING"],
    "sortBy": ["PRICE", "ARRIVAL_TIME", "DURATION", "REFUND_FLEXIBILITY"]
  }
}
