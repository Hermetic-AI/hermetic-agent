{
  "$id": "auip.flight_query.ask_user.v1",
  "title": "flight_query scenario - ask_user tool schema",
  "description": "LLM 调 ask_user 工具时, 工具入参的 JSON Schema。card_type 受白名单约束;body/fields/actions 等为业务字段。",
  "type": "object",
  "required": ["card_type"],
  "properties": {
    "card_type": {
      "type": "string",
      "enum": ["FLIGHT_RESULT", "CANNOT_ORDER", "CHAT_FALLBACK"],
      "description": "前端 FlightResultCard 已实现的 card_type 优先选 FLIGHT_RESULT; 错误/空结果用 CANNOT_ORDER; 兜底走 CHAT_FALLBACK"
    },
    "title": {
      "type": "string",
      "description": "卡片标题。FLIGHT_RESULT 通常用 '机票已发送'"
    },
    "dismissible": {
      "type": "boolean",
      "default": false,
      "description": "用户能否关掉卡片 (false = 强制交互)"
    },
    "body": {
      "type": "object",
      "description": "卡片自由内容,按 card_type 走不同 schema",
      "oneOf": [
        {
          "title": "FLIGHT_RESULT body",
          "properties": {
            "summary": {
              "type": "object",
              "required": ["totalCount", "filteredCount", "searchType", "depCity", "arrCity", "depDate"],
              "properties": {
                "totalCount": { "type": "integer", "minimum": 0, "description": "MCP 原始 flightList 长度" },
                "filteredCount": { "type": "integer", "minimum": 0, "description": "过滤后 flightList 长度" },
                "searchType": { "type": "string", "description": "全量查询 / 经济舱最低价 / 公务舱最低价" },
                "depCity": { "type": "string" },
                "arrCity": { "type": "string" },
                "depDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "weather": { "type": "string", "description": "可选,出发/到达城市天气" }
              }
            },
            "plans": {
              "type": "array",
              "minItems": 1,
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": ["id", "title", "flights"],
                "properties": {
                  "id": { "type": "string", "description": "方案 id: fastest/cheapest/comfortable" },
                  "title": { "type": "string", "description": "方案标题: 最快抵达 / 最便宜 / 直飞首选" },
                  "subtitle": { "type": "string", "description": "副标题: 用时最短 / 价格最低 / 舒适首选" },
                  "criteria": { "type": "string", "description": "排序维度: duration/price/shareFlight" },
                  "flights": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 3,
                    "items": { "$ref": "#/$defs/flight" }
                  }
                }
              }
            }
          }
        },
        {
          "title": "CANNOT_ORDER body",
          "properties": {
            "reason": { "type": "string", "description": "用户可见原因,如 '暂无符合条件的航班'" },
            "fallback": { "type": "string", "description": "建议下一步,如 '放宽日期 / 换舱等 / 换 OD'" }
          }
        }
      ]
    },
    "actions": {
      "type": "array",
      "description": "可选决策按钮; FLIGHT_RESULT 通常省略, CANNOT_ORDER 可加 '我知道了'",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "style": { "enum": ["primary", "secondary", "danger", "ghost"] }
        }
      }
    }
  },
  "$defs": {
    "flight": {
      "type": "object",
      "required": ["flightId", "flightNo", "airline", "departure", "arrival", "duration", "price"],
      "properties": {
        "flightId": { "type": "string" },
        "flightNo": { "type": "string" },
        "shareFlight": { "type": "boolean" },
        "shareInfo": { "type": "string", "description": "共享航班说明: '共享MU5116'" },
        "airline": {
          "type": "object",
          "required": ["code", "name"],
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "aircraft": { "type": "string" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "departure": {
          "type": "object",
          "required": ["city", "airport", "airportCode", "time"],
          "properties": {
            "city": { "type": "string" },
            "airport": { "type": "string" },
            "airportCode": { "type": "string" },
            "terminal": { "type": "string" },
            "time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" }
          }
        },
        "arrival": {
          "type": "object",
          "required": ["city", "airport", "airportCode", "time"],
          "properties": {
            "city": { "type": "string" },
            "airport": { "type": "string" },
            "airportCode": { "type": "string" },
            "terminal": { "type": "string" },
            "time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" }
          }
        },
        "duration": { "type": "string", "description": "如 '2h20m'" },
        "stops": { "type": "integer", "minimum": 0, "description": "0 = 直飞" },
        "cabin": { "type": "string" },
        "cabinClass": { "enum": ["ECONOMY", "PREMIUM_ECONOMY", "BUSINESS", "FIRST"] },
        "meal": { "type": "string" },
        "price": { "type": "number", "description": "最低价 (元)" },
        "fullPrice": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
