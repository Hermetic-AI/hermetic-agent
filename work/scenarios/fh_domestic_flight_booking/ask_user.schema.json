{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auip.fh_domestic_flight_booking.ask_user.v1",
  "title": "FH domestic flight booking ask_user schema",
  "description": "Tool input schema for ask_user. The hub converts this payload into an AUIP card SSE event.",
  "type": "object",
  "required": ["card_type", "title"],
  "additionalProperties": true,
  "properties": {
    "card_type": {
      "type": "string",
      "enum": [
        "OD_INPUT",
        "FLIGHT_RESULT",
        "FLIGHT_LIST",
        "CABIN_LIST",
        "PASSENGER_FORM",
        "OAT_BINDING",
        "PRICE_VERIFY",
        "POLICY_DECISION",
        "ORDER_CONFIRM",
        "ORDER_SUCCESS",
        "CANNOT_ORDER",
        "CHAT_FALLBACK"
      ]
    },
    "schema_version": { "type": "string", "default": "1.0" },
    "title": { "type": "string", "minLength": 1 },
    "message": { "type": "string" },
    "body": { "type": "object", "additionalProperties": true },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    },
    "options": {
      "type": "array",
      "items": { "$ref": "#/$defs/option" }
    },
    "flights": {
      "type": "array",
      "items": { "$ref": "#/$defs/selection_item" }
    },
    "cabins": {
      "type": "array",
      "items": { "$ref": "#/$defs/selection_item" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "decision_buttons": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "current_price": { "type": "number" },
    "original_price": { "type": "number" },
    "price_diff": { "type": "number" },
    "policy_overrun": { "type": "boolean" },
    "policy_hint": { "type": "string" },
    "order_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "order_no": { "type": "string" },
    "total_price": { "type": "number" },
    "reason": { "type": "string" },
    "fallback": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "dismissible": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "card_type": { "const": "OD_INPUT" } } },
      "then": { "required": ["fields"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "FLIGHT_RESULT" } } },
      "then": {
        "required": ["body"],
        "properties": {
          "body": {
            "type": "object",
            "required": ["summary", "plans"],
            "properties": {
              "summary": { "$ref": "#/$defs/flight_summary" },
              "plans": {
                "type": "array",
                "items": { "$ref": "#/$defs/flight_plan" }
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "card_type": { "const": "FLIGHT_LIST" } } },
      "then": { "required": ["flights"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "CABIN_LIST" } } },
      "then": { "required": ["cabins"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "PASSENGER_FORM" } } },
      "then": { "required": ["fields"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "OAT_BINDING" } } },
      "then": {
        "anyOf": [
          { "required": ["fields"] },
          { "required": ["options"] }
        ]
      }
    },
    {
      "if": { "properties": { "card_type": { "const": "PRICE_VERIFY" } } },
      "then": { "required": ["current_price"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "POLICY_DECISION" } } },
      "then": {
        "anyOf": [
          { "required": ["decision_buttons"] },
          { "required": ["actions"] }
        ]
      }
    },
    {
      "if": { "properties": { "card_type": { "const": "ORDER_CONFIRM" } } },
      "then": { "required": ["order_summary"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "ORDER_SUCCESS" } } },
      "then": {
        "anyOf": [
          { "required": ["order_no"] },
          { "required": ["order_summary"] }
        ]
      }
    },
    {
      "if": { "properties": { "card_type": { "const": "CANNOT_ORDER" } } },
      "then": { "required": ["reason", "fallback"] }
    },
    {
      "if": { "properties": { "card_type": { "const": "CHAT_FALLBACK" } } },
      "then": { "required": ["message"] }
    }
  ],
  "$defs": {
    "field": {
      "type": "object",
      "required": ["id", "label", "type"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["text", "textarea", "date", "number", "select"]
        },
        "required": { "type": "boolean" },
        "placeholder": { "type": "string" },
        "default": {},
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": true,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "code": { "type": "string" },
        "style": {
          "type": "string",
          "enum": ["primary", "secondary", "danger", "ghost"]
        },
        "confirm": { "type": "boolean" },
        "surcharge": { "type": "number" }
      }
    },
    "selection_item": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "flightId": { "type": "string" },
        "cabId": { "type": "string" },
        "title": { "type": "string" },
        "label": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "flightNo": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "fare": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "flight_summary": {
      "type": "object",
      "required": ["totalCount", "filteredCount", "searchType", "depCity", "arrCity", "depDate"],
      "additionalProperties": true,
      "properties": {
        "totalCount": { "type": "integer" },
        "filteredCount": { "type": "integer" },
        "searchType": { "type": "string" },
        "depCity": { "type": "string" },
        "arrCity": { "type": "string" },
        "depDate": { "type": "string" },
        "weather": { "type": "string" }
      }
    },
    "flight_plan": {
      "type": "object",
      "required": ["id", "title", "flights"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "criteria": { "type": "string" },
        "flights": {
          "type": "array",
          "items": { "$ref": "#/$defs/flight_segment" }
        }
      }
    },
    "flight_segment": {
      "type": "object",
      "required": [
        "flightId",
        "flightNo",
        "airline",
        "date",
        "departure",
        "arrival",
        "duration",
        "stops",
        "cabin",
        "price"
      ],
      "additionalProperties": true,
      "properties": {
        "flightId": { "type": "string" },
        "flightNo": { "type": "string" },
        "airline": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "date": { "type": "string" },
        "departure": { "$ref": "#/$defs/flight_endpoint" },
        "arrival": { "$ref": "#/$defs/flight_endpoint" },
        "duration": { "type": "string" },
        "stops": { "type": "integer" },
        "cabin": { "type": "string" },
        "cabinClass": { "type": "string" },
        "price": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "flight_endpoint": {
      "type": "object",
      "required": ["city", "airport", "airportCode", "time"],
      "additionalProperties": true,
      "properties": {
        "city": { "type": "string" },
        "airport": { "type": "string" },
        "airportCode": { "type": "string" },
        "terminal": { "type": "string" },
        "time": { "type": "string" }
      }
    }
  }
}
