# ============================================================
# OpenAgent Docker 部署环境变量
# 复制�?.env 填实际�? cp .env.example .env
# ============================================================

# ---- LLM 凭证 (二选一或并�? scenario �?model 字符串决定用哪个) ----

# 方案 A: Anthropic Claude
# 适用 model: anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-xxx

# 方案 B: OpenAI 兼容端点 (推荐 �?DeepSeek/Qwen/GLM/Ollama/自建)
# 适用 model: openai/<模型 id>
OPENAI_API_KEY=sk-cp-82Swn_Zh7ydotS37skz39JCfTUS_sD8LQcKOCl54sQsGTEF2dBr_OSVheWVs6-kljTj2gBF9fvs0A_7rQOBPyr3ec1Jkk4Ioa0cRXt1_KEvWacLvQNzEa3w
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM:       https://open.bigmodel.cn/api/paas/v4/
# Moonshot:  https://api.moonshot.cn/v1
# Ollama:    http://host.docker.internal:11434/v1
# 自建:      http://your-llm-host:port/v1
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# ---- skill 业务 API (场景里要调哪�?MCP 就填哪些) ----
FLIGHT_API_KEY=i6lntfr1qaibi9cgm3m1

# ---- Workspace (host 上项目根, 容器�?mount 到同路径) ----
# Windows: D:/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
# Linux:   /work/tenant-A/project-1
# macOS:   /Users/you/projects/openagent/work/tenant-A/project-1
#WORKSPACE_HOST_PATH=/run/desktop/mnt/host/c/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
# ---- Skill �?(中心服务持有, 容器�?ro bind) ----
#SKILLS_SHARED_DIR=/run/desktop/mnt/host/c/WorkSpace/Coding/OpenAgent/work/shared/skills
WORKSPACE_HOST_PATH=/mnt/c/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
SKILLS_SHARED_DIR=/mnt/c/WorkSpace/Coding/OpenAgent/work/shared/skills
# ---- Policy (Phase 1 静态文�? Phase 2 Hub 动态生�? ----
# 这里面是 scenario 配置 (model / skills / tool_level), �?docker/render_config.py
#POLICY_FILE=/run/desktop/mnt/host/c/WorkSpace/Coding/OpenAgent/work/sandbox/policy.opencode-1.json
POLICY_FILE=/mnt/c/WorkSpace/Coding/OpenAgent/work/sandbox/policy.opencode-1.json
# ---- Hub 内部 ----
# OPENCODE_NODES=http://opencode-1:14096     # 默认 compose 写死
# ROUTING_STRATEGY=sticky_session             # sticky / least_sessions / round_robin / weighted

# ---- 日志 ----
AGENT_SCHEDULER_LOG_LEVEL=DEBUG
AGENT_SCHEDULER_LOG_FORMAT=json
AGENT_SCHEDULER_LOG_LLM_PAYLOAD=true

# ---- 存储 (Phase 1 内存) ----
AGENT_SCHEDULER_STORAGE_BACKEND=memory

# ---- Hub 跟 opencode 节点连接 ----
AGENT_SCHEDULER_OPENCODE_BASE_URL=http://opencode-1:14096

# ---- Skill 路径 (容器内) ----
AGENT_SCHEDULER_SKILL_PATHS=["/app/src/openagent/.skills"]

# ---- MCP 工具配置 ----
# 本地开发: 直接给空列表 (不挂 MCP 工具)
AGENT_SCHEDULER_MCP_TOOLS_CONFIG=[]
# Docker / 部署: 也可以指向容器内 JSON 文件, Settings 会自动读 + 解析
# AGENT_SCHEDULER_MCP_TOOLS_CONFIG=/app/work/mcp/mcp.json

