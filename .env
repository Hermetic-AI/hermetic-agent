# 方案 B: OpenAI 兼容端点 (推荐 �?DeepSeek/Qwen/GLM/Ollama/自建)
# 适用 model: openai/<模型 id>

OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=sk-cp-82Swn_Zh7ydotS37skz39JCfTUS_sD8LQcKOCl54sQsGTEF2dBr_OSVheWVs6-kljTj2gBF9fvs0A_7rQOBPyr3ec1Jkk4Ioa0cRXt1_KEvWacLvQNzEa3w
#OPENAI_API_KEY=sk-572f0295b31c4475bccffe53f5f9e142
#OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- skill 业务 API (场景里要调哪�?MCP 就填哪些) ----
# TODO: 生产换 secret manager, 别把真 token 写进 .env (git tracked)
# 当前 dev 用: 用户给的真 token, 验证 MCP 路由.
FLIGHT_API_KEY=i6lo7pg2dqesb0qbij5p
# 显式关闭 mcporter 桥（mcporter 0.12.0 不支持 Streamable HTTP，改用 opencode 原生 remote MCP 直连）
MCPORTER_ENABLED=false
MCPORTER_CONFIG_PATH=/opt/sandbox/mcporter.json
MCPORTER_SERVERS=feihe-travel

# ---- Workspace (host 上项目根, 容器内 mount 到同路径) ----
# Windows: D:/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
# Linux:   /work/tenant-A/project-1
# macOS:   /Users/you/projects/openagent/work/tenant-A/project-1
#WORKSPACE_PATH=/run/desktop/mnt/host/c/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
#WORKSPACE_PATH=D:/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
WORKSPACE_PATH=/mnt/c/WorkSpace/Coding/fh-openagent/work/tenant-A/project-1

# ---- Skill 源 (中心服务持有, 容器内 ro bind) ----
#SKILLS_SHARED_DIR=/run/desktop/mnt/host/c/WorkSpace/Coding/OpenAgent/work/shared/skills
SKILLS_SHARED_DIR=./work/shared/skills



# ---- 存储 (Phase 1 内存) ----
STORAGE_BACKEND=memory

# ---- Hub 跟 opencode 节点连接 ----
OPENCODE_BASE_URL=http://opencode-1:14096

# ---- Skill 路径 (容器内) ----
SKILL_PATHS=["/app/src/openagent/.skills"]

# ---- MCP 工具配置 ----
# 本地开发: 直接给空列表 (不挂 MCP 工具)
MCP_TOOLS_CONFIG=[]
# Docker / 部署: 也可以指向容器内 JSON 文件, Settings 会自动读 + 解析
# MCP_TOOLS_CONFIG=/app/work/mcp/mcp.json


# =====================================================================
# 4. Storage
# =====================================================================

# Phase 1 内存即可, Phase 2 接 Postgres
# STORAGE_BACKEND=postgres
STORAGE_BACKEND=mysql
# MySQL (Phase 2 主存储, 跟 docker run -d -p 13306:3306 对齐)
MYSQL_DSN=mysql://root:1014@192.168.3.16:13306/openagent
MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20
MYSQL_ECHO=false

# ---- 日志 ----
LOG_LEVEL=DEBUG
#LOG_FORMAT=console  #json
LOG_FORMAT=json
LOG_LLM_PAYLOAD=true
# .env 里打开
LOG_USE_REDIS_LOG=true
LOG_QUEUE_NAME=dev_queue
LOG_SYSTEM_TYPE=ai_dev
#LOG_QUEUE_NAME=openagent
#LOG_SYSTEM_TYPE=openagent_prod
LOG_REDIS_HOST=10.100.30.21
LOG_REDIS_PORT=6379
LOG_REDIS_PASSWORD=
LOG_INSTANCE_ID=hub-A
LOG_REDIS_DATABASE=15
