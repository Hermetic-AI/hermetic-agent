# OpenAgent Frontend 镜像 compose 用的环境变量样例
# 用法:  cp docker-compose.frontend.env.example .env
#        docker compose -f docker-compose.frontend.yml --env-file .env up -d --build
#
# 也支持 shell 直接 export, 优先级: shell env > --env-file > 这里

# ---- Frontend 镜像 (build 模式用 :dev, image 模式用 registry tag) ----
# 跟 build 字段并存: 设了 OPENAGENT_FRONTEND_IMAGE 走 image 模式, 否则用 :dev
OPENAGENT_FRONTEND_IMAGE=ghcr.io/your-org/openagent-frontend:1.0.0
# 拉取策略: always (image 模式) / never / missing / if_not_present
OPENAGENT_FRONTEND_PULL_POLICY=always

# ---- LLM 凭证 (跟原 compose 一样) ----
# Anthropic (用 anthropic/* 时填)
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI 兼容 (用 openai/* 时填, 推荐 — DeepSeek/Qwen/GLM/Ollama/自建)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- skill 业务 API ----
# FLIGHT_API_KEY=...

# ---- 路径 (host 上 workspace + skill 源) ----
# WORKSPACE_HOST_PATH=/work/tenant-A/project-1
# SKILLS_SHARED_DIR=./work/shared/skills

# ---- 日志 ----
AGENT_SCHEDULER_LOG_LEVEL=INFO
AGENT_SCHEDULER_LOG_FORMAT=json
AGENT_SCHEDULER_LOG_LLM_PAYLOAD=true
