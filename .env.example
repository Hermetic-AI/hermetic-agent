# ============================================================
# hermetic_agent Docker 部署环境变量
# 复制�?.env 填实际�? cp .env.example .env
# ------------------------------------------------------------
# 全部 Hub �?Python 动态配置都�?src/hermetic_agent/config/settings.py,
# 字段 -> 环境变量映射规则: pydantic-settings 配的 ```` 前缀
# �? settings.opencode_admin_port �?OPENCODE_ADMIN_PORT
# 复杂字段 (list[dict]) 支持 inline JSON �?JSON 文件路径.
# ============================================================

# ---- LLM 凭证 (二选一或并�? scenario �?model 字符串决定用哪个) ----

# 方案 A: Anthropic Claude
# 适用 model: anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-xxx

# 方案 B: OpenAI 兼容端点 (推荐 �?DeepSeek/Qwen/GLM/Ollama/自建)
# 适用 model: openai/<模型 id>
OPENAI_API_KEY=sk-xxx
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM:       https://open.bigmodel.cn/api/paas/v4/
# Moonshot:  https://api.moonshot.cn/v1
# Ollama:    http://host.docker.internal:11434/v1
# 自建:      http://your-llm-host:port/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- 业务 SKILL 需要的 env (基座不识别, 透传到 opencode 容器) ----
# 业务 SKILL 在 skill.yaml 的 required_envs 段声明自己需要的 env, 基座
# 会在每个 chat 之前把同名 env 写到 opencode 容器 env.runtime.
# 业务侧填写示例:
# MCP_TOKEN=your-business-api-token
# MYAPP_API_BASE=https://api.your-company.com/v1


# =====================================================================
# 1. Server (Hub 进程 + Sanic + CORS)
# =====================================================================

# Hub 监听
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# CORS
CORS_ORIGINS=["*"]

# Sanic 超时 (P8: �?LLM 调用必须撑住; 默认 10s/5s 必断)
# 都是**上限**而非**真实等待**; 业务流自然结束会立即释放.
SANIC_REQUEST_TIMEOUT=600
SANIC_REQUEST_MAX_SIZE=50000000
SANIC_KEEP_ALIVE_TIMEOUT=120
SANIC_WEBSOCKET_PING_TIMEOUT=60
SANIC_WEBSOCKET_PONG_TIMEOUT=60


# =====================================================================
# 2. OpenCode �?opencode_serve 客户�?(HTTP / admin / reload)
# =====================================================================

# OpenCode serve 地址 (Hub �?chat / session)
OPENCODE_BASE_URL=http://opencode-1:14096
# OpenCode Basic Auth (目前没启, 留空)
# OPENCODE_USERNAME=
# OPENCODE_PASSWORD=

# OpenCode 容器�?admin server 端口 (Hub �?env.runtime + 触发 reload)
OPENCODE_ADMIN_PORT=7778

# Hub 触发 opencode reload �? 等待 supervisor 拉起新进程的最短秒�?
OPENCODE_RELOAD_SETTLE_SECONDS=1.0
# opencode serve 启动�?/global/health 探活总超�?(�?
OPENCODE_WAIT_HEALTH_TIMEOUT=8.0
OPENCODE_WAIT_HEALTH_INTERVAL=0.25


# =====================================================================
# 3. Logging
# =====================================================================

# log_level:  DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
# log_format: console (本地开�? Rich 配色) / json (生产, �?ELK/Loki)
LOG_FORMAT=json
LOG_LLM_PAYLOAD=true
# 容器�?stdout 不是 TTY, Rich 默认关色。docker-compose.yml 已硬编码
# FORCE_COLOR=1 + TERM=xterm-256color; 这里是给本机/裸跑场景的覆盖口�?
# FORCE_COLOR=1
# TERM=xterm-256color

# ---- 3a. 外部日志采集平台接入 (仿照 fh-ai app/commons/log) ----
# DTO 字段 + 接入指南�?docs/design/外部日志采集平台接入指南.md
# 默认全关 (use_redis_log=false), 需要接平台时开 use_redis_log=true
LOG_USE_REDIS_LOG=false
# Redis List �?(不含 log: 前缀), 平台订阅 log:{queueName}
LOG_QUEUE_NAME=hermetic_agent
# Redis List 满后丢弃本批, 不阻塞主流程
LOG_MAX_QUEUE_SIZE=100000
# use_redis_log=false 时的文件路径, 留空 = 不落�?
# LOG_FILE_PATH=/var/log/hermetic_agent/platform.log
# stdout tee: 把平台日�?(BusiLog/RequestLog) 也打�?stdout �?structlog 并存,
# �?[platform-log] 前缀. 默认�?�?生产打开会双�? 仅本�?dev �?
LOG_TEE_TO_STDOUT=false
# type 字段后缀 (BUSI_LOG_<TYPE>), 生产可改 hermetic_agent_prod
LOG_SYSTEM_TYPE=hermetic_agent
# RedisWriteTask 轮询间隔 (�?, �?fh-ai 一�?0.5s
LOG_REDIS_POLL_INTERVAL=0.5
# Redis 连接 (跟业�?Redis 独立, 不要混用)
LOG_REDIS_HOST=10.100.30.21
LOG_REDIS_PORT=6379
# LOG_REDIS_PASSWORD=
LOG_REDIS_DATABASE=0
LOG_REDIS_TIMEOUT=5.0
# 实例标识, 留空 = 自动 (HOSTNAME + hash)
# LOG_INSTANCE_ID=hub-A


# =====================================================================
# 4. Storage
# =====================================================================

# Phase 1 内存即可, Phase 2 �?Postgres
# STORAGE_BACKEND=postgres
STORAGE_BACKEND=mysql
# MySQL (Phase 2 主存�? �?docker run -d -p 13306:3306 对齐)
MYSQL_DSN=mysql://root:1014@127.0.0.1:13306/hermetic_agent
MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20
MYSQL_ECHO=false
# �?Postgres 字段保留兼容(暂未启用)
# POSTGRES_DSN=postgresql://localhost:5432/hermetic_agent
# POSTGRES_POOL_MIN_SIZE=5
# POSTGRES_POOL_MAX_SIZE=20


# =====================================================================
# 5. Skill Runtime
# =====================================================================

# Skill 路径 (显式加载, 优先�?fallback 候选目�?
# SKILL_PATHS=["/app/src/hermetic_agent/.skills"]
# Skill 路径 fallback 候选目�?(相对 CWD 或绝对路�? 依次探测)
# SKILL_PATH_FALLBACKS=["src/hermetic_agent/.skills","work/shared/skills","/app/src/hermetic_agent/.skills","/app/work/shared/skills"]

# FragmentLoader: 预算 (token) + 超预算策�?
FRAGMENT_BUDGET_TOKENS=4000
# policy: error / warn / truncate
FRAGMENT_BUDGET_POLICY=error


# =====================================================================
# 6. MCP
# =====================================================================

# MCP Tools 配置. 两种写法任选一�? Settings 会自动识别.
#   1) inline JSON (本地开发推荐)
# MCP_TOOLS_CONFIG=[]
#   2) 指向 JSON 文件的路径 (容器 / 部署场景)
# MCP_TOOLS_CONFIG=/app/work/mcp/mcp.json
# 文件内容示例: [{"name": "my-mcp", "remote_url": "http://...", "input_schema": {...}}]
MCP_TOOLS_CONFIG=[]

# MCPorter bridge (可选: 启用后 opencode 配置中用 mcporter
# 这个本地 MCP server 代理业务 upstream, 由业务 SKILL 在 skill.yaml 声明
# MCPORTER_ENABLED=false
# MCPORTER_CONFIG_PATH=/opt/sandbox/mcporter.json
# MCPORTER_SERVERS=my-mcp-server


# =====================================================================
# 7. Agent
# =====================================================================

# 启动时自动注册默�?Agent (指向 OPENCODE_BASE_URL)
AUTO_REGISTER_DEFAULT_AGENTS=true
# 覆盖默认 Agent 列表 (留空�?opencode-core)
# DEFAULT_AGENTS_JSON=[{"name":"agent-1","base_url":"http://...","sdk_type":"opencode","default_model":"openai/..."}]


# =====================================================================
# 8. Sandbox (Phase 1 单机�? 容器�?Hub 启动 sandbox)
# =====================================================================

# docker CLI 路径
DOCKER_BIN=docker
# sandbox �?hub 共享�?docker bridge network �?(�?docker-compose 对齐)
SANDBOX_NETWORK=hermetic_agent-sandbox-net
# 资源限制
SANDBOX_MEM_LIMIT=2g
SANDBOX_CPU_LIMIT=2.0
SANDBOX_PIDS_LIMIT=128
# 端口
SANDBOX_HEALTH_PORT=7777
SANDBOX_OPENCODE_PORT=14096
# 探活
SANDBOX_HEALTH_CHECK_TIMEOUT=2.0
SANDBOX_HEALTH_CHECK_RETRIES=3


# =====================================================================
# 9. Policy �?L5 安全策略
# =====================================================================

# network=local 模式下也允许的出网端�?(DNS / local services �?
NETWORK_ALLOWED_LOCAL_PORTS=[80,443,53,8080,8443,3000,5000,5432,6379]
# 永远不允许的路径 glob 模式 (凭据类文�?
PATH_BLOCKED_PATTERNS=["**/.env","**/.env.*","**/id_rsa","**/id_ed25519","**/id_*","**/.ssh/**","**/.aws/credentials","**/.config/gcloud/**","**/*.pem","**/*.key","**/*.p12","**/secrets/**","**/credentials/**"]


# =====================================================================
# 10. Scenario
# =====================================================================

SCENARIO_PATHS=["work/scenarios"]
DEFAULT_SCENARIO=_default
WORK_ROOT=work
# ${PROJECT_DIR} 占位符兜底�?(相对 work_root 或绝对路�?
PROJECT_DIR_FALLBACK=tenants/tenant-A/projects/project-1


# =====================================================================
# 11. Launcher �?engine 启动 / cwd 校验
# =====================================================================

# opencode serve 临时 config.json 写入目录
LAUNCHER_CONFIG_DIR=work/cache/opencode-configs
# EngineLauncher 拒绝�?cwd (cwd 是这些或占位符没解析时会�?LauncherRefusedRoot)
LAUNCHER_FORBIDDEN_CWDS=["/","~","${HOME}","$HOME","/root","/home",""]
# scenario_security 没传�? opencode config 渲染的默认�?
LAUNCHER_DEFAULT_TOOL_LEVEL=standard
LAUNCHER_DEFAULT_NETWORK=local
# opencode serve --hostname (loopback 避免对外暴露)
LAUNCHER_OPENCODE_HOSTNAME=127.0.0.1
# EngineLauncher.stop �?SIGTERM 生效秒数, 超时强杀
LAUNCHER_STOP_GRACE_SECONDS=5.0


# =====================================================================
# 12. Chat / SSE �?流式响应 + MCP token
# =====================================================================

# SSE 心跳间隔 (�?. 业务事件空闲超这个时�? 注入 ": keepalive" 注释�?
# 防止 Vite proxy / Nginx / 浏览器在 30-60s 后关连接.
SSE_KEEPALIVE_INTERVAL=15.0

# opencode SDK 底层 httpx client 超时 (�?
OPENCODE_CLIENT_TIMEOUT_CONNECT=10.0
OPENCODE_CLIENT_TIMEOUT_READ=300.0
OPENCODE_CLIENT_TIMEOUT_WRITE=10.0
OPENCODE_CLIENT_TIMEOUT_POOL=5.0
# opencode SDK 底层 httpx client 连接�?
OPENCODE_CLIENT_MAX_CONNECTIONS=100
OPENCODE_CLIENT_MAX_KEEPALIVE=100
OPENCODE_CLIENT_KEEPALIVE_EXPIRY=120.0

# AgentPoolService 单实例 /health 探活 HTTP 超时 (秒)
AGENT_POOL_HEALTH_CHECK_HTTP_TIMEOUT=5.0


# =====================================================================
# 13. App Metadata — OpenAPI 文档
# =====================================================================

APP_TITLE=hermetic-agent
APP_VERSION=0.1.0
# APP_DESCRIPTION=
APP_CONTACT_EMAIL=dev@hermetic_agent.local
APP_LICENSE_NAME=MIT


# =====================================================================
# 调度 / 健康检�?(老字�? �?server / opencode 段语义重�? 保留兼容)
# =====================================================================
# 任务默认超时 (�?
DEFAULT_TIMEOUT=120.0
# 健康检查间�?(�? �?agent_pool �?
HEALTH_CHECK_INTERVAL=30.0
# 连续失败 N 次后 mark_offline
MAX_RETRIES=3


# =====================================================================
# Workspace (host 上项目根, 容器�?mount 到同路径)
# =====================================================================
# Windows: D:/WorkSpace/Coding/hermetic_agent/work/tenant-A/project-1
# Linux:   /work/tenant-A/project-1
# macOS:   /Users/you/projects/hermetic_agent/work/tenant-A/project-1
# 这是 sandbox 容器的工作目�? host 跟容器同路径 (agent 透明).
WORKSPACE_PATH=./work/tenant-A/project-1

# ---- Skill �?(中心服务持有, 容器�?ro bind) ----
SKILLS_SHARED_DIR=./work/shared/skills


# =====================================================================
# Docker Compose 模式
# 统一 docker-compose.yml 通过 PULL_POLICY �?local / registry 间切�?
# (�?service 设计, �?profile hack)
# =====================================================================

# PULL_POLICY �?1 (默认 missing):
#   missing (默认):  本地有就�? 没才�?�?等价�?优先 build 产物"
#   never:           严格只用本地, 缺镜像报�?�?严格 dev / 离线
#   always:          强制�?registry �? 忽略本地 �?触发 registry 模式
#   if_not_present:  等价 missing
# PULL_POLICY=missing

# 镜像 tag (registry 模式�? local 模式可忽�?
# HERMETIC_AGENT_IMAGE=ghcr.io/your-org/hermetic-agent:1.0.0
# OPENCODE_SANDBOX_IMAGE=ghcr.io/your-org/opencode-sandbox:1.0.0
# HERMETIC_AGENT_FRONTEND_IMAGE=ghcr.io/your-org/hermetic_agent-frontend:1.0.0

# 启动命令 (4 �? PULL_POLICY + --profile frontend 切换):
#   local 模式 (默认):   docker compose up -d --build
#   registry 模式 (生产): PULL_POLICY=always docker compose up -d
#   local + frontend:     docker compose --profile frontend up -d --build
#   registry + frontend:  PULL_POLICY=always docker compose --profile frontend up -d


# =====================================================================
# 15. Nacos (配置中心 + AI 注册表: MCP/Agent/Skill/Prompt)
# =====================================================================

# 是否启用 Nacos 集成 (关闭后所有 Nacos 功能跳过)
NACOS_ENABLED=true
# Nacos Server 地址 (Docker 部署 = nacos:8848, 本地 = 127.0.0.1:8848)
# 集群模式用逗号分隔: nacos-1:8848,nacos-2:8848
NACOS_SERVER_ADDR=nacos:8848
# Nacos 命名空间 ID (留空 = public, 用于环境/租户隔离)
# 示例: local 命名空间
NACOS_NAMESPACE=6375a990-9df8-4783-a7fe-fb3a3effba93
# Nacos 配置分组
NACOS_GROUP=DEFAULT_GROUP
# Nacos 认证 (3.x 默认开启 auth)
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
# 配置中心 Data ID + Group + 格式
NACOS_CONFIG_DATA_ID=hermetic_agent
NACOS_CONFIG_GROUP=DEFAULT_GROUP
NACOS_CONFIG_FORMAT=yaml
# AI 注册表功能开关
NACOS_AI_ENABLED=true
# MCP Server 同步: 本地 MCPRegistry → Nacos MCP 注册表
NACOS_AI_MCP_SYNC=true
# Agent Card 同步: 本地 AgentPool → Nacos A2A Agent 注册表
NACOS_AI_AGENT_SYNC=true
# Skill 同步: 本地 SkillRegistry → Nacos Skill 注册表
NACOS_AI_SKILL_SYNC=true
# Prompt 同步: Nacos Prompt 注册表 → 本地 SkillRegistry
NACOS_AI_PROMPT_SYNC=true
# Hub 在 Nacos 服务注册表中的服务名 + 端口
NACOS_SERVICE_NAME=hermetic-agent
NACOS_SERVICE_PORT=8000


# =====================================================================
# 16. MinIO (asset object storage) — skill 文件中心
# =====================================================================

# MinIO (asset object storage)
MINIO_ROOT_USER=hermetic-agent-minio
MINIO_ROOT_PASSWORD=minio-secret-dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_SKILLS=hermetic-agent-skills

# Hub asset backend: 'memory' for dev/test, 'minio' for compose
AGENT_SCHEDULER_ASSET_BACKEND=minio

# Agent injection master toggle
AGENT_SCHEDULER_AGENT_ENABLED=true
