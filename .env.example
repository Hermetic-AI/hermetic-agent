# ============================================================
# OpenAgent Docker 部署环境变量
# 复制为 .env 填实际值: cp .env.example .env
# ------------------------------------------------------------
# 全部 Hub 侧 Python 动态配置都在 src/openagent/config/settings.py,
# 字段 -> 环境变量映射规则: pydantic-settings 配的 ```` 前缀
# 例: settings.opencode_admin_port ↔ OPENCODE_ADMIN_PORT
# 复杂字段 (list[dict]) 支持 inline JSON 或 JSON 文件路径.
# ============================================================

# ---- LLM 凭证 (二选一或并存, scenario 的 model 字符串决定用哪个) ----

# 方案 A: Anthropic Claude
# 适用 model: anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-xxx

# 方案 B: OpenAI 兼容端点 (推荐 — DeepSeek/Qwen/GLM/Ollama/自建)
# 适用 model: openai/<模型 id>
OPENAI_API_KEY=sk-xxx
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM:       https://open.bigmodel.cn/api/paas/v4/
# Moonshot:  https://api.moonshot.cn/v1
# Ollama:    http://host.docker.internal:11434/v1
# 自建:      http://your-llm-host:port/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- skill 业务 API (场景里要调哪些 MCP 就填哪些) ----
FLIGHT_API_KEY=flight-xxx


# =====================================================================
# 1. Server (Hub 进程 + Sanic + CORS)
# =====================================================================

# Hub 监听
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# CORS
CORS_ORIGINS=["*"]

# Sanic 超时 (P8: 长 LLM 调用必须撑住; 默认 10s/5s 必断)
# 都是**上限**而非**真实等待**; 业务流自然结束会立即释放.
SANIC_REQUEST_TIMEOUT=600
SANIC_REQUEST_MAX_SIZE=50000000
SANIC_KEEP_ALIVE_TIMEOUT=120
SANIC_WEBSOCKET_PING_TIMEOUT=60
SANIC_WEBSOCKET_PONG_TIMEOUT=60


# =====================================================================
# 2. OpenCode — opencode_serve 客户端 (HTTP / admin / reload)
# =====================================================================

# OpenCode serve 地址 (Hub 调 chat / session)
OPENCODE_BASE_URL=http://opencode-1:14096
# OpenCode Basic Auth (目前没启, 留空)
# OPENCODE_USERNAME=
# OPENCODE_PASSWORD=

# OpenCode 容器内 admin server 端口 (Hub 写 env.runtime + 触发 reload)
OPENCODE_ADMIN_PORT=7778

# Hub 触发 opencode reload 后, 等待 supervisor 拉起新进程的最短秒数
OPENCODE_RELOAD_SETTLE_SECONDS=1.0
# opencode serve 启动后 /global/health 探活总超时 (秒)
OPENCODE_WAIT_HEALTH_TIMEOUT=8.0
OPENCODE_WAIT_HEALTH_INTERVAL=0.25


# =====================================================================
# 3. Logging
# =====================================================================

# log_level:  DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
# log_format: console (本地开发, Rich 配色) / json (生产, 给 ELK/Loki)
LOG_FORMAT=json
LOG_LLM_PAYLOAD=true
# 容器内 stdout 不是 TTY, Rich 默认关色。docker-compose.yml 已硬编码
# FORCE_COLOR=1 + TERM=xterm-256color; 这里是给本机/裸跑场景的覆盖口。
# FORCE_COLOR=1
# TERM=xterm-256color

# ---- 3a. 外部日志采集平台接入 (仿照 fh-ai app/commons/log) ----
# DTO 字段 + 接入指南见 docs/design/外部日志采集平台接入指南.md
# 默认全关 (use_redis_log=false), 需要接平台时开 use_redis_log=true
LOG_USE_REDIS_LOG=false
# Redis List 名 (不含 log: 前缀), 平台订阅 log:{queueName}
LOG_QUEUE_NAME=openagent
# Redis List 满后丢弃本批, 不阻塞主流程
LOG_MAX_QUEUE_SIZE=100000
# use_redis_log=false 时的文件路径, 留空 = 不落盘
# LOG_FILE_PATH=/var/log/openagent/platform.log
# stdout tee: 把平台日志 (BusiLog/RequestLog) 也打到 stdout 跟 structlog 并存,
# 加 [platform-log] 前缀. 默认关 — 生产打开会双发, 仅本地 dev 用
LOG_TEE_TO_STDOUT=false
# type 字段后缀 (BUSI_LOG_<TYPE>), 生产可改 openagent_prod
LOG_SYSTEM_TYPE=openagent
# RedisWriteTask 轮询间隔 (秒), 跟 fh-ai 一致 0.5s
LOG_REDIS_POLL_INTERVAL=0.5
# Redis 连接 (跟业务 Redis 独立, 不要混用)
LOG_REDIS_HOST=10.100.30.21
LOG_REDIS_PORT=6379
# LOG_REDIS_PASSWORD=
LOG_REDIS_DATABASE=0
LOG_REDIS_TIMEOUT=5.0
# 实例标识, 留空 = 自动 (HOSTNAME + hash)
# LOG_INSTANCE_ID=hub-A


# =====================================================================
# 4. Storage
# =====================================================================

# Phase 1 内存即可, Phase 2 接 Postgres
# STORAGE_BACKEND=postgres
STORAGE_BACKEND=mysql
# MySQL (Phase 2 主存储, 跟 docker run -d -p 13306:3306 对齐)
MYSQL_DSN=mysql://root:1014@127.0.0.1:13306/openagent
MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20
MYSQL_ECHO=false
# 老 Postgres 字段保留兼容(暂未启用)
# POSTGRES_DSN=postgresql://localhost:5432/openagent
# POSTGRES_POOL_MIN_SIZE=5
# POSTGRES_POOL_MAX_SIZE=20


# =====================================================================
# 5. Skill Runtime
# =====================================================================

# Skill 路径 (显式加载, 优先于 fallback 候选目录)
# SKILL_PATHS=["/app/src/openagent/.skills"]
# Skill 路径 fallback 候选目录 (相对 CWD 或绝对路径; 依次探测)
# SKILL_PATH_FALLBACKS=["src/openagent/.skills","work/shared/skills","/app/src/openagent/.skills","/app/work/shared/skills"]

# FragmentLoader: 预算 (token) + 超预算策略
FRAGMENT_BUDGET_TOKENS=4000
# policy: error / warn / truncate
FRAGMENT_BUDGET_POLICY=error


# =====================================================================
# 6. MCP
# =====================================================================

# MCP Tools 配置. 两种写法任选一种, Settings 会自动识别:
#   1) inline JSON (本地开发推荐)
# MCP_TOOLS_CONFIG=[]
#   2) 指向 JSON 文件的路径 (容器内 / 部署场景)
# MCP_TOOLS_CONFIG=/app/work/mcp/mcp.json
# 文件内容示例: [{"name": "flight", "remote_url": "http://...", "input_schema": {...}}]
MCP_TOOLS_CONFIG=[]
# feihe-travel MCP token env 名 (跟 docker/render_config.py 保持一致)
FLIGHT_MCP_TOKEN_ENV=FLIGHT_API_KEY

# MCPorter bridge (可选): 启用后 opencode 配置中用 mcporter
# 这个本地 MCP server 代理 fh-travel,不再直接渲染原生 feihe-travel MCP。
# MCPORTER_ENABLED=false
# MCPORTER_CONFIG_PATH=/opt/sandbox/mcporter.json
# MCPORTER_SERVERS=feihe-travel


# =====================================================================
# 7. Agent
# =====================================================================

# 启动时自动注册默认 Agent (指向 OPENCODE_BASE_URL)
AUTO_REGISTER_DEFAULT_AGENTS=true
# 覆盖默认 Agent 列表 (留空走 opencode-core)
# DEFAULT_AGENTS_JSON=[{"name":"agent-1","base_url":"http://...","sdk_type":"opencode","default_model":"openai/..."}]


# =====================================================================
# 8. Sandbox (Phase 1 单机版, 容器内 Hub 启动 sandbox)
# =====================================================================

# docker CLI 路径
DOCKER_BIN=docker
# sandbox 跟 hub 共享的 docker bridge network 名 (跟 docker-compose 对齐)
SANDBOX_NETWORK=openagent-sandbox-net
# 资源限制
SANDBOX_MEM_LIMIT=2g
SANDBOX_CPU_LIMIT=2.0
SANDBOX_PIDS_LIMIT=128
# 端口
SANDBOX_HEALTH_PORT=7777
SANDBOX_OPENCODE_PORT=14096
# 探活
SANDBOX_HEALTH_CHECK_TIMEOUT=2.0
SANDBOX_HEALTH_CHECK_RETRIES=3


# =====================================================================
# 9. Policy — L5 安全策略
# =====================================================================

# network=local 模式下也允许的出网端口 (DNS / local services 等)
NETWORK_ALLOWED_LOCAL_PORTS=[80,443,53,8080,8443,3000,5000,5432,6379]
# 永远不允许的路径 glob 模式 (凭据类文件)
PATH_BLOCKED_PATTERNS=["**/.env","**/.env.*","**/id_rsa","**/id_ed25519","**/id_*","**/.ssh/**","**/.aws/credentials","**/.config/gcloud/**","**/*.pem","**/*.key","**/*.p12","**/secrets/**","**/credentials/**"]


# =====================================================================
# 10. Scenario
# =====================================================================

SCENARIO_PATHS=["work/scenarios"]
DEFAULT_SCENARIO=_default
WORK_ROOT=work
# ${PROJECT_DIR} 占位符兜底值 (相对 work_root 或绝对路径)
PROJECT_DIR_FALLBACK=tenants/tenant-A/projects/project-1


# =====================================================================
# 11. Launcher — engine 启动 / cwd 校验
# =====================================================================

# opencode serve 临时 config.json 写入目录
LAUNCHER_CONFIG_DIR=work/cache/opencode-configs
# EngineLauncher 拒绝的 cwd (cwd 是这些或占位符没解析时会抛 LauncherRefusedRoot)
LAUNCHER_FORBIDDEN_CWDS=["/","~","${HOME}","$HOME","/root","/home",""]
# scenario_security 没传时, opencode config 渲染的默认值
LAUNCHER_DEFAULT_TOOL_LEVEL=standard
LAUNCHER_DEFAULT_NETWORK=local
# opencode serve --hostname (loopback 避免对外暴露)
LAUNCHER_OPENCODE_HOSTNAME=127.0.0.1
# EngineLauncher.stop 等 SIGTERM 生效秒数, 超时强杀
LAUNCHER_STOP_GRACE_SECONDS=5.0


# =====================================================================
# 12. Chat / SSE — 流式响应 + MCP token
# =====================================================================

# SSE 心跳间隔 (秒). 业务事件空闲超这个时长, 注入 ": keepalive" 注释行,
# 防止 Vite proxy / Nginx / 浏览器在 30-60s 后关连接.
SSE_KEEPALIVE_INTERVAL=15.0

# opencode SDK 底层 httpx client 超时 (秒)
OPENCODE_CLIENT_TIMEOUT_CONNECT=10.0
OPENCODE_CLIENT_TIMEOUT_READ=300.0
OPENCODE_CLIENT_TIMEOUT_WRITE=10.0
OPENCODE_CLIENT_TIMEOUT_POOL=5.0
# opencode SDK 底层 httpx client 连接池
OPENCODE_CLIENT_MAX_CONNECTIONS=100
OPENCODE_CLIENT_MAX_KEEPALIVE=100
OPENCODE_CLIENT_KEEPALIVE_EXPIRY=120.0

# AgentPoolService 单实例 /health 探活 HTTP 超时 (秒)
AGENT_POOL_HEALTH_CHECK_HTTP_TIMEOUT=5.0


# =====================================================================
# 13. Feihe Auth — 飞鹤正式系统代理
# =====================================================================

# 飞鹤正式系统 base URL. Hub /api/auth/logon 跟 /api/auth/captcha 代为调.
# 前端永远不直连这个域名 (避免密码泄露 + CORS).
FEIHE_BASE_URL=https://traveldev.feiheair.com
# Hub 调 feihe 后端的 HTTP 超时秒数
FEIHE_REQUEST_TIMEOUT=10.0
# feihe 后端要求 Origin/Referer 跟这个域一致 (服务端调, 给它写这个域兜住)
FEIHE_ORIGIN_URL=https://crmdev.feiheair.com


# =====================================================================
# 14. App Metadata — OpenAPI 文档
# =====================================================================

APP_TITLE=Agent Scheduler Hub
APP_VERSION=0.1.0
# APP_DESCRIPTION=
APP_CONTACT_EMAIL=dev@openagent.local
APP_LICENSE_NAME=MIT


# =====================================================================
# 调度 / 健康检查 (老字段, 跟 server / opencode 段语义重复, 保留兼容)
# =====================================================================
# 任务默认超时 (秒)
DEFAULT_TIMEOUT=120.0
# 健康检查间隔 (秒) — agent_pool 用
HEALTH_CHECK_INTERVAL=30.0
# 连续失败 N 次后 mark_offline
MAX_RETRIES=3


# =====================================================================
# Workspace (host 上项目根, 容器内 mount 到同路径)
# =====================================================================
# Windows: D:/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
# Linux:   /work/tenant-A/project-1
# macOS:   /Users/you/projects/openagent/work/tenant-A/project-1
# 这是 sandbox 容器的工作目录, host 跟容器同路径 (agent 透明).
WORKSPACE_PATH=./work/tenant-A/project-1

# ---- Skill 源 (中心服务持有, 容器内 ro bind) ----
SKILLS_SHARED_DIR=./work/shared/skills


# =====================================================================
# Docker Compose 模式
# 统一 docker-compose.yml 通过 PULL_POLICY 在 local / registry 间切换
# (单 service 设计, 无 profile hack)
# =====================================================================

# PULL_POLICY 选 1 (默认 missing):
#   missing (默认):  本地有就用, 没才拉 — 等价于"优先 build 产物"
#   never:           严格只用本地, 缺镜像报错 — 严格 dev / 离线
#   always:          强制从 registry 拉, 忽略本地 — 触发 registry 模式
#   if_not_present:  等价 missing
# PULL_POLICY=missing

# 镜像 tag (registry 模式用, local 模式可忽略)
# OPENAGENT_HUB_IMAGE=ghcr.io/your-org/openagent-hub:1.0.0
# OPENCODE_SANDBOX_IMAGE=ghcr.io/your-org/opencode-sandbox:1.0.0
# OPENAGENT_FRONTEND_IMAGE=ghcr.io/your-org/openagent-frontend:1.0.0

# 启动命令 (4 种, PULL_POLICY + --profile frontend 切换):
#   local 模式 (默认):   docker compose up -d --build
#   registry 模式 (生产): PULL_POLICY=always docker compose up -d
#   local + frontend:     docker compose --profile frontend up -d --build
#   registry + frontend:  PULL_POLICY=always docker compose --profile frontend up -d
