# ============================================================
# OpenAgent Docker 部署环境变量
# 复制为 .env 填实际值: cp .env.example .env
# ------------------------------------------------------------
# 全部 Hub 侧 Python 动态配置都在 src/openagent/config/settings.py,
# 字段 -> 环境变量映射规则: pydantic-settings 配的 ``AGENT_SCHEDULER_`` 前缀
# 例: settings.opencode_admin_port ↔ AGENT_SCHEDULER_OPENCODE_ADMIN_PORT
# 复杂字段 (list[dict]) 支持 inline JSON 或 JSON 文件路径.
# ============================================================

# ---- LLM 凭证 (二选一或并存, scenario 的 model 字符串决定用哪个) ----

# 方案 A: Anthropic Claude
# 适用 model: anthropic/claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-xxx

# 方案 B: OpenAI 兼容端点 (推荐 — DeepSeek/Qwen/GLM/Ollama/自建)
# 适用 model: openai/<模型 id>
OPENAI_API_KEY=sk-xxx
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM:       https://open.bigmodel.cn/api/paas/v4/
# Moonshot:  https://api.moonshot.cn/v1
# Ollama:    http://host.docker.internal:11434/v1
# 自建:      http://your-llm-host:port/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- skill 业务 API (场景里要调哪些 MCP 就填哪些) ----
FLIGHT_API_KEY=flight-xxx


# =====================================================================
# 1. Server (Hub 进程 + Sanic + CORS)
# =====================================================================

# Hub 监听
AGENT_SCHEDULER_HOST=0.0.0.0
AGENT_SCHEDULER_PORT=8000
AGENT_SCHEDULER_WORKERS=1
AGENT_SCHEDULER_DEBUG=false

# CORS
AGENT_SCHEDULER_CORS_ORIGINS=["*"]

# Sanic 超时 (P8: 长 LLM 调用必须撑住; 默认 10s/5s 必断)
# 都是**上限**而非**真实等待**; 业务流自然结束会立即释放.
AGENT_SCHEDULER_SANIC_REQUEST_TIMEOUT=600
AGENT_SCHEDULER_SANIC_REQUEST_MAX_SIZE=50000000
AGENT_SCHEDULER_SANIC_KEEP_ALIVE_TIMEOUT=120
AGENT_SCHEDULER_SANIC_WEBSOCKET_PING_TIMEOUT=60
AGENT_SCHEDULER_SANIC_WEBSOCKET_PONG_TIMEOUT=60


# =====================================================================
# 2. OpenCode — opencode_serve 客户端 (HTTP / admin / reload)
# =====================================================================

# OpenCode serve 地址 (Hub 调 chat / session)
AGENT_SCHEDULER_OPENCODE_BASE_URL=http://opencode-1:14096
# OpenCode Basic Auth (目前没启, 留空)
# AGENT_SCHEDULER_OPENCODE_USERNAME=
# AGENT_SCHEDULER_OPENCODE_PASSWORD=

# OpenCode 容器内 admin server 端口 (Hub 写 env.runtime + 触发 reload)
AGENT_SCHEDULER_OPENCODE_ADMIN_PORT=7778

# Hub 触发 opencode reload 后, 等待 supervisor 拉起新进程的最短秒数
AGENT_SCHEDULER_OPENCODE_RELOAD_SETTLE_SECONDS=1.0
# opencode serve 启动后 /global/health 探活总超时 (秒)
AGENT_SCHEDULER_OPENCODE_WAIT_HEALTH_TIMEOUT=8.0
AGENT_SCHEDULER_OPENCODE_WAIT_HEALTH_INTERVAL=0.25


# =====================================================================
# 3. Logging
# =====================================================================

# log_level:  DEBUG / INFO / WARNING / ERROR / CRITICAL
AGENT_SCHEDULER_LOG_LEVEL=INFO
# log_format: console (本地开发, Rich 配色) / json (生产, 给 ELK/Loki)
AGENT_SCHEDULER_LOG_FORMAT=json
AGENT_SCHEDULER_LOG_LLM_PAYLOAD=true
# 容器内 stdout 不是 TTY, Rich 默认关色。docker-compose.yml 已硬编码
# FORCE_COLOR=1 + TERM=xterm-256color; 这里是给本机/裸跑场景的覆盖口。
# FORCE_COLOR=1
# TERM=xterm-256color


# =====================================================================
# 4. Storage
# =====================================================================

# Phase 1 内存即可, Phase 2 接 Postgres
# AGENT_SCHEDULER_STORAGE_BACKEND=postgres
AGENT_SCHEDULER_STORAGE_BACKEND=memory
# AGENT_SCHEDULER_STORAGE_BACKEND=postgres
# AGENT_SCHEDULER_POSTGRES_DSN=postgresql://postgres:123456@127.0.0.1:35432/openagent
AGENT_SCHEDULER_POSTGRES_DSN=postgresql://localhost:5432/openagent
AGENT_SCHEDULER_POSTGRES_POOL_MIN_SIZE=5
AGENT_SCHEDULER_POSTGRES_POOL_MAX_SIZE=20


# =====================================================================
# 5. Skill Runtime
# =====================================================================

# Skill 路径 (显式加载, 优先于 fallback 候选目录)
# AGENT_SCHEDULER_SKILL_PATHS=["/app/src/openagent/.skills"]
# Skill 路径 fallback 候选目录 (相对 CWD 或绝对路径; 依次探测)
# AGENT_SCHEDULER_SKILL_PATH_FALLBACKS=["src/openagent/.skills","work/shared/skills","/app/src/openagent/.skills","/app/work/shared/skills"]

# FragmentLoader: 预算 (token) + 超预算策略
AGENT_SCHEDULER_FRAGMENT_BUDGET_TOKENS=4000
# policy: error / warn / truncate
AGENT_SCHEDULER_FRAGMENT_BUDGET_POLICY=error


# =====================================================================
# 6. MCP
# =====================================================================

# MCP Tools 配置. 两种写法任选一种, Settings 会自动识别:
#   1) inline JSON (本地开发推荐)
# AGENT_SCHEDULER_MCP_TOOLS_CONFIG=[]
#   2) 指向 JSON 文件的路径 (容器内 / 部署场景)
# AGENT_SCHEDULER_MCP_TOOLS_CONFIG=/app/work/mcp/mcp.json
# 文件内容示例: [{"name": "flight", "remote_url": "http://...", "input_schema": {...}}]
AGENT_SCHEDULER_MCP_TOOLS_CONFIG=[]
# feihe-travel MCP token env 名 (跟 docker/render_config.py 保持一致)
AGENT_SCHEDULER_FLIGHT_MCP_TOKEN_ENV=FLIGHT_API_KEY


# =====================================================================
# 7. Agent
# =====================================================================

# 启动时自动注册默认 Agent (指向 OPENCODE_BASE_URL)
AGENT_SCHEDULER_AUTO_REGISTER_DEFAULT_AGENTS=true
# 覆盖默认 Agent 列表 (留空走 opencode-core)
# AGENT_SCHEDULER_DEFAULT_AGENTS_JSON=[{"name":"agent-1","base_url":"http://...","sdk_type":"opencode","default_model":"openai/..."}]


# =====================================================================
# 8. Sandbox (Phase 1 单机版, 容器内 Hub 启动 sandbox)
# =====================================================================

# docker CLI 路径
AGENT_SCHEDULER_DOCKER_BIN=docker
# sandbox 跟 hub 共享的 docker bridge network 名 (跟 docker-compose 对齐)
AGENT_SCHEDULER_SANDBOX_NETWORK=openagent-sandbox-net
# 资源限制
AGENT_SCHEDULER_SANDBOX_MEM_LIMIT=2g
AGENT_SCHEDULER_SANDBOX_CPU_LIMIT=2.0
AGENT_SCHEDULER_SANDBOX_PIDS_LIMIT=128
# 端口
AGENT_SCHEDULER_SANDBOX_HEALTH_PORT=7777
AGENT_SCHEDULER_SANDBOX_OPENCODE_PORT=14096
# 探活
AGENT_SCHEDULER_SANDBOX_HEALTH_CHECK_TIMEOUT=2.0
AGENT_SCHEDULER_SANDBOX_HEALTH_CHECK_RETRIES=3


# =====================================================================
# 9. Policy — L5 安全策略
# =====================================================================

# network=local 模式下也允许的出网端口 (DNS / local services 等)
AGENT_SCHEDULER_NETWORK_ALLOWED_LOCAL_PORTS=[80,443,53,8080,8443,3000,5000,5432,6379]
# 永远不允许的路径 glob 模式 (凭据类文件)
AGENT_SCHEDULER_PATH_BLOCKED_PATTERNS=["**/.env","**/.env.*","**/id_rsa","**/id_ed25519","**/id_*","**/.ssh/**","**/.aws/credentials","**/.config/gcloud/**","**/*.pem","**/*.key","**/*.p12","**/secrets/**","**/credentials/**"]


# =====================================================================
# 10. Scenario
# =====================================================================

AGENT_SCHEDULER_SCENARIO_PATHS=["work/scenarios"]
AGENT_SCHEDULER_DEFAULT_SCENARIO=_default
AGENT_SCHEDULER_WORK_ROOT=work
# ${PROJECT_DIR} 占位符兜底值 (相对 work_root 或绝对路径)
AGENT_SCHEDULER_PROJECT_DIR_FALLBACK=tenants/tenant-A/projects/project-1


# =====================================================================
# 11. Launcher — engine 启动 / cwd 校验
# =====================================================================

# opencode serve 临时 config.json 写入目录
AGENT_SCHEDULER_LAUNCHER_CONFIG_DIR=work/cache/opencode-configs
# EngineLauncher 拒绝的 cwd (cwd 是这些或占位符没解析时会抛 LauncherRefusedRoot)
AGENT_SCHEDULER_LAUNCHER_FORBIDDEN_CWDS=["/","~","${HOME}","$HOME","/root","/home",""]
# scenario_security 没传时, opencode config 渲染的默认值
AGENT_SCHEDULER_LAUNCHER_DEFAULT_TOOL_LEVEL=standard
AGENT_SCHEDULER_LAUNCHER_DEFAULT_NETWORK=local
# opencode serve --hostname (loopback 避免对外暴露)
AGENT_SCHEDULER_LAUNCHER_OPENCODE_HOSTNAME=127.0.0.1
# EngineLauncher.stop 等 SIGTERM 生效秒数, 超时强杀
AGENT_SCHEDULER_LAUNCHER_STOP_GRACE_SECONDS=5.0


# =====================================================================
# 12. Chat / SSE — 流式响应 + MCP token
# =====================================================================

# SSE 心跳间隔 (秒). 业务事件空闲超这个时长, 注入 ": keepalive" 注释行,
# 防止 Vite proxy / Nginx / 浏览器在 30-60s 后关连接.
AGENT_SCHEDULER_SSE_KEEPALIVE_INTERVAL=15.0

# opencode SDK 底层 httpx client 超时 (秒)
AGENT_SCHEDULER_OPENCODE_CLIENT_TIMEOUT_CONNECT=10.0
AGENT_SCHEDULER_OPENCODE_CLIENT_TIMEOUT_READ=300.0
AGENT_SCHEDULER_OPENCODE_CLIENT_TIMEOUT_WRITE=10.0
AGENT_SCHEDULER_OPENCODE_CLIENT_TIMEOUT_POOL=5.0
# opencode SDK 底层 httpx client 连接池
AGENT_SCHEDULER_OPENCODE_CLIENT_MAX_CONNECTIONS=100
AGENT_SCHEDULER_OPENCODE_CLIENT_MAX_KEEPALIVE=100
AGENT_SCHEDULER_OPENCODE_CLIENT_KEEPALIVE_EXPIRY=120.0

# AgentPoolService 单实例 /health 探活 HTTP 超时 (秒)
AGENT_SCHEDULER_AGENT_POOL_HEALTH_CHECK_HTTP_TIMEOUT=5.0


# =====================================================================
# 13. Feihe Auth — 飞鹤正式系统代理
# =====================================================================

# 飞鹤正式系统 base URL. Hub /api/auth/logon 跟 /api/auth/captcha 代为调.
# 前端永远不直连这个域名 (避免密码泄露 + CORS).
AGENT_SCHEDULER_FEIHE_BASE_URL=https://traveldev.feiheair.com
# Hub 调 feihe 后端的 HTTP 超时秒数
AGENT_SCHEDULER_FEIHE_REQUEST_TIMEOUT=10.0
# feihe 后端要求 Origin/Referer 跟这个域一致 (服务端调, 给它写这个域兜住)
AGENT_SCHEDULER_FEIHE_ORIGIN_URL=https://crmdev.feiheair.com


# =====================================================================
# 14. App Metadata — OpenAPI 文档
# =====================================================================

AGENT_SCHEDULER_APP_TITLE=Agent Scheduler Hub
AGENT_SCHEDULER_APP_VERSION=0.1.0
# AGENT_SCHEDULER_APP_DESCRIPTION=
AGENT_SCHEDULER_APP_CONTACT_EMAIL=dev@openagent.local
AGENT_SCHEDULER_APP_LICENSE_NAME=MIT


# =====================================================================
# 调度 / 健康检查 (老字段, 跟 server / opencode 段语义重复, 保留兼容)
# =====================================================================
# 任务默认超时 (秒)
AGENT_SCHEDULER_DEFAULT_TIMEOUT=120.0
# 健康检查间隔 (秒) — agent_pool 用
AGENT_SCHEDULER_HEALTH_CHECK_INTERVAL=30.0
# 连续失败 N 次后 mark_offline
AGENT_SCHEDULER_MAX_RETRIES=3


# =====================================================================
# Workspace (host 上项目根, 容器内 mount 到同路径)
# =====================================================================
# Windows: D:/WorkSpace/Coding/OpenAgent/work/tenant-A/project-1
# Linux:   /work/tenant-A/project-1
# macOS:   /Users/you/projects/openagent/work/tenant-A/project-1
WORKSPACE_HOST_PATH=./work/tenant-A/project-1

# ---- Skill 源 (中心服务持有, 容器内 ro bind) ----
SKILLS_SHARED_DIR=./work/shared/skills

# ---- Policy (Phase 1 静态文件, Phase 2 Hub 动态生成) ----
# 这里面是 scenario 配置 (model / skills / tool_level), 见 docker/render_config.py
POLICY_FILE=./work/sandbox/policy.opencode-1.json
