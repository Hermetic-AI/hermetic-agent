{
  "name": "entropy-management",
  "version": "1.0.0",
  "description": "技术债务追踪与管理：代码质量衰减、文件健康度、重复代码、文档新鲜度、日志卫生、依赖审计",
  "skill_type": "technical-debt",
  "applicable_to": ["opencode", "claude-code", "codex-cli", "cursor", "openclaw", "maxclaw", "autoclaw", "kimiclaw", "trae"],
  "source_files": [
    "harness-rules/entropy-checklist.md",
    "harness-rules/file-limits.json"
  ],
  "capabilities": {
    "file_health": {
      "description": "文件行数健康检查",
      "thresholds": {
        "warning": 200,
        "critical": 300
      },
      "pythonLimit": 300,
      "typescriptLimit": 500,
      "javaLimit": 300
    },
    "duplicate_code": {
      "description": "重复代码检测",
      "tools": {
        "python": "flake8 --select=C4, mvn pmd:cpd",
        "java": "mvn pmd:cpd",
        "typescript": "jscpd"
      },
      "threshold": "5%"
    },
    "utils_audit": {
      "description": "Utils 函数使用次数审计",
      "minCallers": 3,
      "rule": "Functions in utils/ MUST have ≥ 3 callers across different modules"
    },
    "doc_freshness": {
      "description": "文档新鲜度检查",
      "checkpoints": [
        "PROGRESS.md vs git log",
        "New modules have ARCHITECTURE.md entries",
        "API endpoints match API.md",
        "No TODOs older than 30 days"
      ]
    },
    "log_health": {
      "description": "日志卫生检查",
      "patterns": {
        "print_statements": "🔴 High - Replace with logger",
        "debug_without_context": "🟡 Medium - Add contextual data",
        "error_without_followup": "🟡 Medium - Create incident ticket",
        "empty_catch_blocks": "🔴 High - Add logging + handling"
      }
    },
    "coverage_tracking": {
      "description": "测试覆盖率追踪",
      "targets": {
        "critical": {"target": 90, "minimum": 80},
        "business_logic": {"target": 80, "minimum": 70},
        "data_access": {"target": 75, "minimum": 60},
        "utilities": {"target": 60, "minimum": 50}
      }
    },
    "dependency_audit": {
      "description": "依赖审计",
      "tools": {
        "python": "pip list --outdated, safety check",
        "java": "mvn dependency:analyze",
        "typescript": "npm outdated, npm audit"
      },
      "update_cadence": {
        "patch": "monthly",
        "minor": "quarterly",
        "major": "6-monthly"
      }
    }
  },
  "file_limits": {
    "python.tensor.logic.service": {"maxLineLength": 300, "maxFunctionLength": 50, "maxArguments": 5},
    "python.tensor.logic.repository": {"maxLineLength": 300, "maxFunctionLength": 40, "maxArguments": 5},
    "python.tensor.logic.controller": {"maxLineLength": 300, "maxFunctionLength": 30, "maxArguments": 7}
  },
  "maintenance_schedule": {
    "daily": "Run full test suite",
    "weekly": "Run lint + type checks",
    "bi-weekly": "File health + duplicate code check",
    "sprint_end": "Full entropy audit + doc update",
    "monthly": "Dependency audit + updates"
  },
  "created": "2026-06-01",
  "tags": ["technical-debt", "entropy", "code-quality", "documentation", "logging", "coverage", "dependencies"]
}
