{
  "name": "code-quality",
  "version": "1.0.0",
  "description": "代码质量检查：flake8、ESLint、复杂度限制、导入规则和风格一致性检查",
  "skill_type": "code-quality",
  "applicable_to": ["opencode", "claude-code", "codex-cli", "cursor", "openclaw", "maxclaw", "autoclaw", "kimiclaw", "trae"],
  "source_files": [
    "harness-rules/.flake8",
    "harness-rules/eslint-boundaries.json",
    "harness-rules/file-limits.json"
  ],
  "capabilities": {
    "python_linting": {
      "command": "flake8",
      "description": "Python 代码风格和 bug 检查",
      "rules": ["C4 (comprehensions)", "B (bugbear)", "Q (quotes)", "W (warnings)"],
      "max_line_length": 120,
      "max_complexity": 10
    },
    "typescript_linting": {
      "command": "eslint --rule 'boundaries/element-types: error'",
      "description": "TypeScript/React 代码检查和模块边界 enforcement"
    },
    "file_limits": {
      "controller": {"maxLines": 300, "maxFunctionLength": 30, "maxArguments": 7},
      "service": {"maxLines": 300, "maxFunctionLength": 50, "maxArguments": 5},
      "repository": {"maxLines": 300, "maxFunctionLength": 40, "maxArguments": 5}
    },
    "complexity_check": {
      "command": "flake8 --select=C901 --max-complexity=10",
      "description": "圈复杂度检查"
    }
  },
  "installation": {
    "python": "pip install flake8 flake8-bugbear flake8-comprehensions",
    "typescript": "npm install -D eslint eslint-plugin-boundaries"
  },
  "config_files": {
    "python": ".flake8",
    "typescript": "eslint.config.js 或 .eslintrc.json"
  },
  "created": "2026-06-01",
  "tags": ["linting", "code-quality", "flake8", "eslint", "complexity", "style", "python", "typescript"]
}
