# 镜像驱动版 compose 用的环境变量样例
# 用法:  cp docker-compose.image.env.example .env
#        docker compose -f docker-compose.image.yml --env-file .env up -d
#
# 也支持 shell 直接 export, 优先级: shell env > --env-file > 这里

# ---- 镜像 tag (唯一必填) ----
# OpenAgent Hub
OPENAGENT_HUB_IMAGE=ghcr.io/your-org/openagent-hub:1.0.0
# opencode sandbox 容器
OPENCODE_SANDBOX_IMAGE=ghcr.io/your-org/opencode-sandbox:1.0.0

# ---- 私有 registry 凭证 (用 ghcr.io / harbor / 自建 nexus 时填) ----
# 跟 compose 文件不直接挂钩, 走 `docker login` 更简单; 留这里只是备忘.
# GHCR: docker login ghcr.io -u <username> -p <PAT>

# ---- LLM 凭证 (跟原 compose 一样) ----
# Anthropic (用 anthropic/* 时填)
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI 兼容 (用 openai/* 时填, 推荐 — DeepSeek/Qwen/GLM/Ollama/自建)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- skill 业务 API ----
# FLIGHT_API_KEY=...

# ---- 路径 (host 上 workspace + skill 源) ----
# WORKSPACE_HOST_PATH=/work/tenant-A/project-1
# SKILLS_SHARED_DIR=./work/shared/skills

# ---- 日志 ----
AGENT_SCHEDULER_LOG_LEVEL=INFO
AGENT_SCHEDULER_LOG_FORMAT=json
AGENT_SCHEDULER_LOG_LLM_PAYLOAD=true
