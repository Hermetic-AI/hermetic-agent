# OpenAgent Hub 镜像 — 2 阶段, 最大化依赖缓存
#
# 阶段 A (deps):    装第三方依赖 (只 COPY requirements.txt)
# 阶段 B (runtime): 装项目源码 (--no-deps, ~3-5s)
#
# **改 src/openagent/ 任何 .py → 阶段 A 缓存命中, 只跑阶段 B (~3-5s)**
# **改 requirements.txt / pyproject.toml → 阶段 A 失效 → ~2-3 min 装新 deps**
# **首次构建 → 全部重跑 → ~3-4 分钟**
#
# 维护: requirements.txt 必须跟 pyproject.toml [project.dependencies] 同步.
# 改 deps 时: 改 pyproject.toml + 改 requirements.txt 一起, 否则 deploy 镜像用旧 deps.
# 加一个 CI check (TODO) 验证一致.
#
# 构建: docker build -f docker/Dockerfile.openagent -t openagent:dev .
#
# 镜像源: Daocloud (免认证, 国内通用)
# 想换回官方 Docker Hub: 去掉 docker.m.daocloud.io/ 前缀即可

FROM docker.m.daocloud.io/library/python:3.11-slim AS deps

WORKDIR /app

# 系统工具: git (claude-agent-sdk 是 git+https 依赖)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 升级 pip + setuptools + wheel
# 用 BuildKit cache mount 持久化 pip 下载缓存 (跨 build 命中)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -U pip setuptools wheel

# ===== 装第三方 deps (只 COPY requirements.txt, 不 COPY src/) =====
# 改 src/ 任何 .py 不会让这层失效
# 改 requirements.txt / pyproject.toml 会失效 (我们用 pyproject.toml 的 hash 当 cache key)
COPY requirements.txt /app/requirements.txt
COPY pyproject.toml /app/pyproject.toml

# 装第三方依赖 — 加 --require-hashes 关掉 (我们没 lock, 用 loose version)
# BuildKit cache mount 让重复 RUN 命中 pip cache, download 跳过
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir -r requirements.txt

# ===== 阶段 B: 装项目源码 (--no-deps, ~3-5s) =====
FROM deps AS runtime

# 装我们自己的项目 (整个 src/) — --no-deps 跳过依赖解析 (deps 阶段已装), 几秒
COPY src/ /app/src/
# 同样用 cache mount 加速 (虽然 --no-deps 不下载, 但 setuptools build 自己的 wheel 会用 pip cache)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --no-deps .

# 让容器内日志立刻刷出来
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# Sanic 默认监听 0.0.0.0:8000
EXPOSE 8000

# 默认启动命令 (compose 可覆盖)
# 开发模式可改成: python -m openagent.main --reload
CMD ["python", "-m", "openagent.main"]
