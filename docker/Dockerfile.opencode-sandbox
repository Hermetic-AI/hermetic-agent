# opencode-sandbox 镜像 (Phase 1)
#
# 1 个容器 = 1 个 long-running opencode serve 进程.
# 容器内:
#   - entrypoint.sh: 读 /opt/sandbox/policy.json → 渲染 opencode config → 启 opencode serve
#   - health_server.py: 周期 /healthz (供 Hub 探活)
#   - admin_server.py:  改 policy / env / reload opencode (供 Hub 调, 也可 host 直连)
#
# 构建: docker build -f docker/Dockerfile.opencode-sandbox -t opencode-sandbox:dev .
#
# 升级到 Node 24+ (v0.4): opencode-ai 最新版要求 Node >= 20, 用 24 拿最新特性

# 镜像源: Daocloud (免认证, 国内通用)
# 想换回官方 Docker Hub: 去掉 docker.m.daocloud.io/ 前缀即可
FROM docker.m.daocloud.io/library/node:24-slim

# 必要工具: curl (healthcheck), python3 (health_server / render_config)
# Node:24-slim 默认不装 Python, 我们要跑 health_server + render_config.
#
# 重试 3 次: deb.debian.org 偶尔返 502 (特别是 readline-common 这种 "软依赖"
# 性质的包), --fix-missing 兜底让 build 不因单包 502 全盘失败.
RUN for i in 1 2 3; do \
        apt-get update \
        && apt-get install -y --no-install-recommends --fix-missing \
            curl \
            ca-certificates \
            python3 \
            python3-requests \
        && break \
        || { echo "apt-get failed (attempt $i/3), retrying in 5s..."; sleep 5; }; \
    done \
    && rm -rf /var/lib/apt/lists/* \
    && python3 --version

# opencode CLI (全局, 这样 entrypoint 能直接调)
RUN npm install -g opencode-ai@latest \
    && opencode --version

# sandbox 内部件
RUN mkdir -p /opt/sandbox
COPY docker/entrypoint.sh    /opt/sandbox/entrypoint.sh
COPY docker/health_server.py /opt/sandbox/health_server.py
COPY docker/render_config.py /opt/sandbox/render_config.py
COPY docker/admin_server.py  /opt/sandbox/admin_server.py
COPY docker/openapi.json     /opt/sandbox/openapi.json
# policy.json bake 进镜像 (跟 docker-compose.yml 注释一致).
# 不再 bind mount: 原因 — Docker Desktop + WSL2 9P 文件系统会看到
# host 跟 daemon 视图不一致, bind mount 永远把目标当目录.
# 改 policy 后: docker build -f docker/Dockerfile.opencode-sandbox + force-recreate.
COPY work/sandbox/policy.opencode-1.json /opt/sandbox/policy.json
# 关键: 强制 LF 行尾. 源文件从 Windows 编辑器写出时带 CRLF,
# 镜像里 shebang 变 "#!\r/bin/bash\r", Linux 内核 execve() 找不到
# 解释器, 整个容器启动 fail. 一行 sed 兜住.
RUN find /opt/sandbox -type f -exec sed -i 's/\r$//' {} +
RUN chmod +x /opt/sandbox/entrypoint.sh /opt/sandbox/health_server.py /opt/sandbox/render_config.py /opt/sandbox/admin_server.py

# 容器根 FS 是 --read-only, 容器层有 /opt/sandbox (entrypoint 要写 health log),
# 跟 /tmp (tmpfs) 一样运行时写. 容器层目录在 --read-only 下需要 --read-only=false
# 或显式声明可写. 实际 compose 里我们设 read_only=true + tmpfs 挂 /tmp;
# 容器层目录: /opt/sandbox, /root/.config, /root/.local 会被 opencode serve 写,
# 必须在 Dockerfile 里开成可写 (chmod 不够, read_only 模式下整个 FS 锁).
# 解法: opencode 配置写到一个 tmpfs 子路径 (/opt/sandbox/config), 跟 health log 同位置.

# opencode serve 端口 (跟 entrypoint.sh / docker-compose / runtime.py 保持一致)
#  - 14096 = opencode serve (供 Hub 调 SDK, 用项目专属号避免跟 host 上 8080 冲突)
#  - 7777  = health_server (供 Hub 探活)
#  - 7778  = admin_server (改 policy / env / reload opencode)
# 想覆盖: docker run -e OPENCODE_PORT=<port> 或 compose environment
ENV OPENCODE_PORT=14096
EXPOSE 7777 7778 14096

# 健康检查 (走 health_server.py 起的 7777, 不是 opencode 自己的)
HEALTHCHECK --interval=5s --timeout=2s --start-period=10s --retries=3 \
    CMD curl -fsS http://127.0.0.1:7777/healthz || exit 1

# 入口
ENTRYPOINT ["/opt/sandbox/entrypoint.sh"]
